---
const steps = [
  {
    number: '01',
    title: 'Module wählen',
    description: 'Wählen Sie aus 20+ Modulen genau die Funktionen, die Ihr Unternehmen braucht. Starten Sie klein und erweitern Sie jederzeit.',
    icon: '🎯',
  },
  {
    number: '02',
    title: 'Team einladen',
    description: 'Legen Sie Mitarbeiter an, weisen Sie Rollen und Berechtigungen zu. Jeder sieht nur, was er braucht.',
    icon: '👥',
  },
  {
    number: '03',
    title: 'Sofort loslegen',
    description: 'Kein Setup, keine Installation. Vertoo läuft im Browser und als installierbare Web-App auf jedem Gerät.',
    icon: '🚀',
  },
];
---

<section id="ablauf" class="py-24 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-600 uppercase tracking-wider">So funktioniert's</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">In 3 Schritten startklar</h2>
      <p class="mt-4 text-lg text-gray-500">
        Kein kompliziertes Onboarding. Kein Berater nötig.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step) => (
        <div class="relative text-center">
          <div aria-hidden="true" class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white border border-gray-200 shadow-sm text-3xl mb-6">
            {step.icon}
          </div>
          <div class="absolute -top-2 -right-2 md:right-auto md:-left-2 w-8 h-8 rounded-full bg-brand-700 text-white text-xs font-bold flex items-center justify-center">
            {step.number}
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">{step.title}</h3>
          <p class="text-gray-500 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
