---
import { faq } from '../data/faq';
---

<section id="faq" class="py-24 lg:py-32 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-3xl mx-auto px-6">
    <div class="reveal text-center max-w-2xl mx-auto mb-12">
      <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">FAQ</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Häufige Fragen zu VertooERP</h2>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
        Die wichtigsten Antworten zu Funktionsumfang, Hosting, Preisen und Compliance.
      </p>
    </div>

    <div class="space-y-3">
      {faq.map((item, i) => (
        <details
          class="group rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 p-5 sm:p-6 [&_summary::-webkit-details-marker]:hidden"
          open={i === 0}
        >
          <summary class="flex items-center justify-between cursor-pointer text-base sm:text-lg font-semibold text-gray-900 dark:text-white list-none gap-4">
            <span>{item.q}</span>
            <svg aria-hidden="true" class="w-5 h-5 shrink-0 text-brand-700 dark:text-brand-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="mt-3 text-sm sm:text-base text-gray-600 dark:text-gray-300 leading-relaxed">{item.a}</p>
          {item.sources && (
            <p class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500 dark:text-gray-400">
              <span class="font-medium">Quellen:</span>
              {item.sources.map((s) => (
                <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-brand-700 dark:text-brand-400 hover:underline">
                  {s.label} ↗
                </a>
              ))}
            </p>
          )}
        </details>
      ))}
    </div>
  </div>
</section>
