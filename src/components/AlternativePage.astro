---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { Icon } from 'astro-icon/components';
import type { Alternative } from '../data/alternatives';
import type { Lang } from '../i18n/ui';
import { localizePath } from '../i18n/utils';
import { getAlternatives } from '../data/localized';

interface Props {
  alt: Alternative;
  lang: Lang;
}

const { alt, lang } = Astro.props;
const p = (path: string) => localizePath(path, lang);
const others = getAlternatives(lang).filter((a) => a.slug !== alt.slug);

const s = {
  de: {
    start: 'Start', alternatives: 'Alternativen', country: 'Deutschland',
    reasonsEyebrow: 'Wann eine Alternative?', diffEyebrow: 'Was VertooERP ausmacht',
    diffHeading: 'Die Unterschiede auf einen Blick', fairness: 'Fair bleiben',
    faqEyebrow: 'Häufige Fragen', demo: 'Demo anfragen', allCompare: 'Alle Vergleiche',
    moreHeading: 'Weitere Vergleiche',
  },
  en: {
    start: 'Home', alternatives: 'Alternatives', country: 'Germany',
    reasonsEyebrow: 'When to consider an alternative', diffEyebrow: 'What sets VertooERP apart',
    diffHeading: 'The differences at a glance', fairness: 'Being fair',
    faqEyebrow: 'FAQ', demo: 'Request a demo', allCompare: 'All comparisons',
    moreHeading: 'More comparisons',
  },
}[lang];

const siteUrl = 'https://vertoo.de';
const url = `${siteUrl}${p(`/alternativen/${alt.slug}`)}`;

const faqLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: alt.faq.map((i) => ({ '@type': 'Question', name: i.q, acceptedAnswer: { '@type': 'Answer', text: i.a } })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: s.start, item: `${siteUrl}${p('/')}` },
    { '@type': 'ListItem', position: 2, name: s.alternatives, item: `${siteUrl}${p('/alternativen')}` },
    { '@type': 'ListItem', position: 3, name: alt.competitor, item: url },
  ],
};
---

<Layout title={alt.metaTitle} description={alt.metaDescription} jsonLd={[faqLd, breadcrumbLd]} hasTranslation>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 hero-gradient overflow-hidden">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500 dark:text-gray-400">
          <a href={p('/')} class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{s.start}</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href={p('/alternativen')} class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{s.alternatives}</a>
        </nav>
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 dark:bg-brand-950/60 text-brand-700 dark:text-brand-300 text-xs font-medium mb-6">
          <span aria-hidden="true" class="w-1.5 h-1.5 rounded-full bg-brand-500"></span>
          {alt.hero.eyebrow}
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">{alt.hero.headline}</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-500 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">{alt.hero.subhead}</p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={p('/#kontakt')} class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-brand-700 text-white font-semibold hover:bg-brand-800 transition-all hover:shadow-lg hover:shadow-brand-700/25 text-center">{s.demo}</a>
          <a href={p('/alternativen')} class="w-full sm:w-auto px-8 py-3.5 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-center">{s.allCompare}</a>
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">{alt.intro}</p>
      </div>
    </section>

    <section class="py-16 lg:py-24 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">{s.reasonsEyebrow}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{alt.reasons.intro}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {alt.reasons.items.map((r) => (
            <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
              <div aria-hidden="true" class="w-11 h-11 rounded-xl bg-brand-50 dark:bg-gray-900 text-brand-600 dark:text-brand-400 flex items-center justify-center mb-3"><Icon name={`lucide:${r.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{r.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">{r.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">{s.diffEyebrow}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{s.diffHeading}</h2>
          <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{alt.differentiators.intro}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {alt.differentiators.items.map((d) => (
            <article class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover">
              <div aria-hidden="true" class="w-12 h-12 rounded-xl bg-brand-50 dark:bg-gray-800 text-brand-600 dark:text-brand-400 flex items-center justify-center mb-4"><Icon name={`lucide:${d.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{d.name}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{d.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Fairness -->
    <section class="py-8 lg:py-12">
      <div class="max-w-3xl mx-auto px-6">
        <div class="rounded-2xl border border-brand-100 dark:border-brand-900/50 bg-brand-50/40 dark:bg-brand-950/30 p-6 sm:p-8 flex items-start gap-4">
          <span aria-hidden="true" class="w-10 h-10 shrink-0 rounded-xl bg-white dark:bg-gray-800 border border-brand-100 dark:border-gray-700 flex items-center justify-center text-brand-600 dark:text-brand-400"><Icon name="lucide:scale" class="w-5 h-5" /></span>
          <div>
            <h2 class="text-sm font-semibold text-brand-700 dark:text-brand-400 uppercase tracking-wider mb-1">{s.fairness}</h2>
            <p class="text-gray-700 dark:text-gray-200 leading-relaxed">{alt.fairness}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-24 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">{s.faqEyebrow}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{alt.competitor} vs. VertooERP</h2>
        </div>
        <div class="space-y-3">
          {alt.faq.map((item, i) => (
            <details class="group rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 p-5 sm:p-6 [&_summary::-webkit-details-marker]:hidden" open={i === 0}>
              <summary class="flex items-center justify-between cursor-pointer text-base sm:text-lg font-semibold text-gray-900 dark:text-white list-none gap-4">
                <span>{item.q}</span>
                <svg aria-hidden="true" class="w-5 h-5 shrink-0 text-brand-700 dark:text-brand-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-3 text-sm sm:text-base text-gray-600 dark:text-gray-300 leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {others.length > 0 && (
      <section class="py-12 lg:py-16">
        <div class="max-w-4xl mx-auto px-6 text-center">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-5">{s.moreHeading}</h2>
          <div class="flex flex-wrap justify-center gap-2.5">
            {others.map((a) => (
              <a href={p(`/alternativen/${a.slug}`)} class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-200 hover:border-brand-300 hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{a.competitor}</a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="py-20 lg:py-28 bg-brand-700">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">{alt.cta.headline}</h2>
        <p class="mt-4 text-lg text-white/90 max-w-2xl mx-auto">{alt.cta.text}</p>
        <a href={p('/#kontakt')} class="mt-8 inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white text-brand-700 font-semibold hover:bg-brand-50 transition-colors">{s.demo}</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
