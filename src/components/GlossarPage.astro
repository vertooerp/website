---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getLangFromUrl, localizePath } from '../i18n/utils';
import { getGlossar } from '../data/localized';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const glossar = getGlossar(lang);

const s = {
  de: {
    title: 'ERP-Glossar – VertooERP',
    description: 'Verständliche Definitionen zu ERP, GoBD, DSGVO, Dropshipping, XRechnung, Self-Hosting und weiteren Begriffen rund um Unternehmenssoftware für den Mittelstand.',
    start: 'Start', eyebrow: 'Glossar', headline: 'ERP-Begriffe verständlich erklärt',
    intro: 'Kurze, klare Definitionen zu den wichtigsten Begriffen rund um ERP, Buchhaltung, Handel und Digitalisierung.',
    ldName: 'VertooERP ERP-Glossar',
    ldDescription: 'Definitionen zentraler Begriffe rund um ERP, Buchhaltung, Handel und Digitalisierung für KMU und Mittelstand.',
    navLabel: 'Begriffe',
  },
  en: {
    title: 'ERP glossary – VertooERP',
    description: 'Clear definitions of ERP, GoBD, GDPR, dropshipping, e-invoicing, self-hosting and other terms around business software for mid-sized companies.',
    start: 'Home', eyebrow: 'Glossary', headline: 'ERP terms explained clearly',
    intro: 'Short, clear definitions of the most important terms around ERP, accounting, commerce and digitalisation.',
    ldName: 'VertooERP ERP glossary',
    ldDescription: 'Definitions of key terms around ERP, accounting, commerce and digitalisation for SMEs and mid-sized companies.',
    navLabel: 'Terms',
  },
}[lang];

const siteUrl = 'https://vertoo.de';
const glossarUrl = `${siteUrl}${p('/glossar')}`;

const definedTermSetLd = {
  '@context': 'https://schema.org', '@type': 'DefinedTermSet',
  name: s.ldName, description: s.ldDescription, url: glossarUrl,
  hasDefinedTerm: glossar.map((t) => ({ '@type': 'DefinedTerm', name: t.term, description: t.definition, url: `${glossarUrl}#${t.slug}` })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: s.start, item: `${siteUrl}${p('/')}` },
    { '@type': 'ListItem', position: 2, name: s.eyebrow, item: glossarUrl },
  ],
};
---

<Layout title={s.title} description={s.description} jsonLd={[definedTermSetLd, breadcrumbLd]} hasTranslation>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-12 lg:pt-40 hero-gradient overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500 dark:text-gray-400">
          <a href={p('/')} class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{s.start}</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <span class="text-gray-700 dark:text-gray-300">{s.eyebrow}</span>
        </nav>
        <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">{s.eyebrow}</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">{s.headline}</h1>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{s.intro}</p>
      </div>
    </section>

    <section class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <nav aria-label={s.navLabel} class="flex flex-wrap gap-2 mb-12">
          {glossar.map((t) => (
            <a href={`#${t.slug}`} class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-brand-50 dark:hover:bg-gray-700 hover:text-brand-700 dark:hover:text-brand-400 transition-colors">
              {t.term}
            </a>
          ))}
        </nav>

        <dl class="space-y-10">
          {glossar.map((t) => (
            <div id={t.slug} class="scroll-mt-24">
              <dt class="text-xl font-bold text-gray-900 dark:text-white">{t.term}</dt>
              <dd class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">{t.definition}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
