---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { Icon } from 'astro-icon/components';
import type { Modul } from '../data/module';
import type { Lang } from '../i18n/ui';
import { localizePath } from '../i18n/utils';
import { getModule, getBranchen } from '../data/localized';

interface Props {
  modul: Modul;
  lang: Lang;
}

const { modul, lang } = Astro.props;
const p = (path: string) => localizePath(path, lang);

// Interne Verlinkung: andere Module + alle Branchen
const otherModules = getModule(lang).filter((m) => m.slug !== modul.slug).slice(0, 6);
const allBranchen = getBranchen(lang);

const s = {
  de: {
    start: 'Start', modules: 'Module', demo: 'Demo anfragen', allModules: 'Alle Module',
    whatIs: (n: string) => `Was ist ${n}?`, problems: 'Probleme', functions: 'Funktionen',
    inDetail: (n: string) => `${n} im Detail`, faqEyebrow: 'Häufige Fragen',
    faqHeading: (n: string) => `Fragen zu ${n}`, country: 'Deutschland',
    moreEyebrow: 'Weiter im ERP', moreModules: 'Weitere Module', forIndustries: 'Passend für Ihre Branche',
  },
  en: {
    start: 'Home', modules: 'Modules', demo: 'Request a demo', allModules: 'All modules',
    whatIs: (n: string) => `What is ${n}?`, problems: 'Challenges', functions: 'Features',
    inDetail: (n: string) => `${n} in detail`, faqEyebrow: 'FAQ',
    faqHeading: (n: string) => `Questions about ${n}`, country: 'Germany',
    moreEyebrow: 'More in the ERP', moreModules: 'More modules', forIndustries: 'A fit for your industry',
  },
}[lang];

const siteUrl = 'https://vertoo.de';
const url = `${siteUrl}${p(`/module/${modul.slug}`)}`;

const serviceLd = {
  '@context': 'https://schema.org', '@type': 'Service', serviceType: modul.name,
  name: modul.metaTitle, description: modul.metaDescription,
  provider: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)', url: siteUrl },
  areaServed: { '@type': 'Country', name: s.country },
  isPartOf: { '@type': 'SoftwareApplication', name: 'VertooERP', applicationCategory: 'BusinessApplication' },
};
const faqLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: modul.faq.map((item) => ({ '@type': 'Question', name: item.q, acceptedAnswer: { '@type': 'Answer', text: item.a } })),
};
const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: s.start, item: `${siteUrl}${p('/')}` },
    { '@type': 'ListItem', position: 2, name: s.modules, item: `${siteUrl}${p('/module')}` },
    { '@type': 'ListItem', position: 3, name: modul.name, item: url },
  ],
};
---

<Layout title={modul.metaTitle} description={modul.metaDescription} jsonLd={[serviceLd, faqLd, breadcrumbLd]} hasTranslation>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 hero-gradient overflow-hidden">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500 ">
          <a href={p('/')} class="hover:text-brand-700  transition-colors">{s.start}</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href={p('/module')} class="hover:text-brand-700  transition-colors">{s.modules}</a>
        </nav>
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50  text-brand-700  text-xs font-medium mb-6">
          <span aria-hidden="true" class="inline-flex"><Icon name={`lucide:${modul.icon}`} class="w-3.5 h-3.5" /></span>
          {modul.hero.eyebrow}
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">{modul.hero.headline}</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-500  leading-relaxed max-w-2xl mx-auto">{modul.hero.subhead}</p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={p('/#kontakt')} class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-brand-700 text-white font-semibold hover:bg-brand-800 transition-all hover:shadow-lg hover:shadow-brand-700/25 text-center">{s.demo}</a>
          <a href={p('/#module')} class="w-full sm:w-auto px-8 py-3.5 rounded-xl border border-gray-200  text-gray-700  font-semibold hover:bg-gray-50  transition-colors text-center">{s.allModules}</a>
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">{s.whatIs(modul.name)}</h2>
        <p class="text-lg text-gray-600  leading-relaxed">{modul.intro}</p>
      </div>
    </section>

    <section class="py-16 lg:py-24 bg-gray-50 ">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{s.problems}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{modul.painpoints.intro}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-4xl mx-auto">
          {modul.painpoints.items.map((pp) => (
            <div class="p-6 rounded-2xl bg-white  border border-gray-100 ">
              <div aria-hidden="true" class="w-11 h-11 rounded-xl bg-brand-50  text-brand-600  flex items-center justify-center mb-3"><Icon name={`lucide:${pp.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900  mb-2">{pp.title}</h3>
              <p class="text-sm text-gray-600  leading-relaxed">{pp.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{s.functions}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{s.inDetail(modul.name)}</h2>
          <p class="mt-4 text-lg text-gray-500 ">{modul.features.intro}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {modul.features.items.map((f) => (
            <article class="p-6 rounded-2xl border border-gray-100  bg-white  card-hover">
              <div aria-hidden="true" class="w-12 h-12 rounded-xl bg-brand-50  text-brand-600  flex items-center justify-center mb-4"><Icon name={`lucide:${f.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900  mb-2">{f.name}</h3>
              <p class="text-sm text-gray-500  leading-relaxed">{f.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 lg:py-24 bg-gray-50 ">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{s.faqEyebrow}</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{s.faqHeading(modul.name)}</h2>
        </div>
        <div class="space-y-3">
          {modul.faq.map((item, i) => (
            <details class="group rounded-2xl bg-white  border border-gray-100  p-5 sm:p-6 [&_summary::-webkit-details-marker]:hidden" open={i === 0}>
              <summary class="flex items-center justify-between cursor-pointer text-base sm:text-lg font-semibold text-gray-900  list-none gap-4">
                <span>{item.q}</span>
                <svg aria-hidden="true" class="w-5 h-5 shrink-0 text-brand-700  transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-3 text-sm sm:text-base text-gray-600  leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Interne Verlinkung: weitere Module + Branchen -->
    <section class="py-16 lg:py-24">
      <div class="max-w-6xl mx-auto px-6">
        <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{s.moreEyebrow}</span>
        <h2 class="mt-3 text-2xl sm:text-3xl font-bold">{s.moreModules}</h2>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {otherModules.map((m) => (
            <a href={p(`/module/${m.slug}`)} class="group flex items-center gap-3 p-4 rounded-xl border border-gray-100  bg-white  card-hover hover:border-brand-200  focus:outline-none focus:ring-2 focus:ring-brand-500">
              <span aria-hidden="true" class="w-10 h-10 shrink-0 rounded-lg bg-brand-50  text-brand-600  flex items-center justify-center"><Icon name={`lucide:${m.icon}`} class="w-5 h-5" /></span>
              <span class="font-semibold text-gray-900  group-hover:text-brand-700  transition-colors">{m.name}</span>
            </a>
          ))}
        </div>

        <h2 class="mt-12 text-2xl sm:text-3xl font-bold">{s.forIndustries}</h2>
        <div class="mt-6 flex flex-wrap gap-3">
          {allBranchen.map((b) => (
            <a href={p(`/branchen/${b.slug}`)} class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium border border-gray-200  bg-white  text-gray-700  hover:border-brand-300 hover:text-brand-700  transition-colors">
              <Icon name={`lucide:${b.icon}`} class="w-4 h-4" />
              {b.name}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-28 bg-brand-700">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">{modul.cta.headline}</h2>
        <p class="mt-4 text-lg text-white/90 max-w-2xl mx-auto">{modul.cta.text}</p>
        <a href={p('/#kontakt')} class="mt-8 inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white text-brand-700 font-semibold hover:bg-brand-50 transition-colors">{s.demo}</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
