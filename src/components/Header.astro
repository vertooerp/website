---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath('/', lang);

const navLinks = [
  { href: localizePath('/#module', lang), label: t('nav.module') },
  { href: localizePath('/#ablauf', lang), label: t('nav.how') },
  { href: localizePath('/#preise', lang), label: t('nav.pricing') },
  { href: localizePath('/#branchen', lang), label: t('nav.industries') },
  { href: localizePath('/blog', lang), label: t('nav.blog') },
  { href: localizePath('/#kontakt', lang), label: t('nav.contact') },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80  backdrop-blur-lg border-b border-gray-100 ">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={home} class="group flex items-center gap-2.5">
      <div aria-hidden="true" class="w-9 h-9 rounded-[10px] bg-brand-700 flex items-center justify-center">
        <!-- Bildmarke: Strich-V mit Häkchen-Anklang (identisch zu favicon.svg) -->
        <svg viewBox="0 0 32 32" class="w-[22px] h-[22px]" fill="none" aria-hidden="true">
          <path d="M9.5 11.5 L15 21.5 L22.5 8.5" stroke="white" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <!--
        Header-Lockup bewusst clean (Marke + Name — Wegweiser-Ebene). Die
        Namensherkunft "VERwaltungsTOOl" erscheint als Micro-Interaction erst
        bei Hover/Fokus unter der Wortmarke (absolut positioniert, kein Layout-
        Shift); permanent erzählt wird sie im Footer. Justierung: tracking so
        getunt, dass die Zeile exakt auf Wortmarken-Breite ausläuft.
      -->
      <span class="relative flex flex-col justify-center" data-logo-lockup>
        <span class="font-display text-xl font-bold text-gray-900 leading-none" data-wordmark>Vertoo<span class="text-gray-400">ERP</span></span>
        <span
          aria-hidden="true"
          class="absolute left-0 top-full mt-1 text-[11px] tracking-[0.088em] leading-none whitespace-nowrap opacity-0 -translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 group-focus-visible:opacity-100 group-focus-visible:translate-y-0 motion-reduce:transition-none"
          data-descriptor
        >
          <span class="font-bold text-brand-700">Ver</span><span class="font-medium text-gray-500">waltungs</span><span class="font-bold text-brand-700">too</span><span class="font-medium text-gray-500">l</span>
        </span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label={t('a11y.nav.main')}>
      {navLinks.slice(0, 5).map((l) => (
        <a href={l.href} class="text-sm text-gray-600  hover:text-brand-700  transition-colors">{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href={localizePath('/#kontakt', lang)} class="hidden md:inline-flex text-sm text-gray-600  hover:text-brand-700  transition-colors">{t('nav.contact')}</a>

      <div class="hidden sm:block"><LanguageSwitcher /></div>

      <a href="/konto" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-700 text-white text-sm font-medium hover:bg-brand-800 transition-colors">
        {t('nav.login')}
      </a>

      <!-- Hamburger (nur Mobile) -->
      <button
        id="menu-toggle"
        type="button"
        aria-label={t('a11y.menu.open')}
        data-label-open={t('a11y.menu.open')}
        data-label-close={t('a11y.menu.close')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-600  hover:bg-gray-100  focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile-Menü (Vollbild-Overlay unter dem Header) -->
  <nav
    id="mobile-menu"
    aria-label={t('a11y.nav.mobile')}
    class="hidden md:hidden fixed inset-x-0 top-16 z-40 h-[calc(100dvh-4rem)] bg-white  overflow-y-auto overscroll-contain"
  >
    <div class="flex flex-col min-h-full px-6 py-4">
      <ul class="flex-1 divide-y divide-gray-100 ">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="flex items-center justify-between py-4 text-lg font-medium text-gray-800  hover:text-brand-700  transition-colors"
            >
              {l.label}
              <svg aria-hidden="true" class="w-5 h-5 text-gray-300 " fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
      <div class="pt-6 pb-4 space-y-3">
        <a href={localizePath('/#kontakt', lang)} class="block w-full py-3.5 rounded-xl bg-brand-700 text-white font-semibold text-center hover:bg-brand-800 transition-colors">
          {t('cta.demo')}
        </a>
        <a href="/konto" class="block w-full py-3.5 rounded-xl border border-gray-200  text-gray-700  font-semibold text-center hover:bg-gray-50  transition-colors">
          {t('nav.login')}
        </a>
        <div class="pt-3 flex justify-center"><LanguageSwitcher /></div>
        <!-- Signatur: Namensherkunft für Mobile (kein Hover auf Touch) -->
        <p aria-hidden="true" class="pt-2 text-center text-[10px] tracking-[0.04em] leading-none">
          <span class="font-bold text-brand-700">Ver</span><span class="font-medium text-gray-400">waltungs</span><span class="font-bold text-brand-700">too</span><span class="font-medium text-gray-400">l</span>
        </p>
      </div>
    </div>
  </nav>
</header>

<script>
  // Namensherkunft einmal pro Session sanft einblenden — löst die fehlende
  // Hover-Geste auf Touch (und Desktop-Discovery gleich mit). Dekorativ,
  // daher bei reduced-motion komplett übersprungen.
  // Inline-Styles statt Klasse: gewinnen sicher gegen die Utility-Layer;
  // transition-all am Element animiert Ein- und Ausblendung trotzdem.
  const descriptor = document.querySelector<HTMLElement>('header [data-descriptor]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  try {
    if (descriptor && !reducedMotion && !sessionStorage.getItem('vertoo-lockup-seen')) {
      sessionStorage.setItem('vertoo-lockup-seen', '1');
      setTimeout(() => {
        descriptor.style.opacity = '1';
        descriptor.style.translate = '0 0';
      }, 900);
      setTimeout(() => {
        descriptor.style.removeProperty('opacity');
        descriptor.style.removeProperty('translate');
      }, 3800);
    }
  } catch (e) {}

  // Mobile-Menü
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  const setMenu = (open: boolean) => {
    if (!mobileMenu || !menuToggle) return;
    mobileMenu.classList.toggle('hidden', !open);
    menuToggle.setAttribute('aria-expanded', String(open));
    menuToggle.setAttribute('aria-label', open ? (menuToggle.dataset.labelClose || 'Close menu') : (menuToggle.dataset.labelOpen || 'Open menu'));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    // Hintergrund-Scroll sperren, solange das Overlay offen ist
    document.body.style.overflow = open ? 'hidden' : '';
  };

  menuToggle?.addEventListener('click', () => {
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
    setMenu(!isOpen);
  });

  // Schließen bei Klick auf einen Link
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  // Schließen mit Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });
</script>
