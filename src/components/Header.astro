---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const home = localizePath('/', lang);

const navLinks = [
  { href: localizePath('/#module', lang), label: t('nav.module') },
  { href: localizePath('/#ablauf', lang), label: t('nav.how') },
  { href: localizePath('/#preise', lang), label: t('nav.pricing') },
  { href: localizePath('/#branchen', lang), label: t('nav.industries') },
  { href: localizePath('/blog', lang), label: t('nav.blog') },
  { href: localizePath('/#kontakt', lang), label: t('nav.contact') },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-lg border-b border-gray-100 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={home} class="group relative flex items-center gap-2.5">
      <div aria-hidden="true" class="w-8 h-8 rounded-lg bg-brand-700 flex items-center justify-center">
        <span class="text-white font-bold text-sm">V</span>
      </div>
      <span class="flex flex-col justify-center">
        <span class="text-xl font-bold text-gray-900 dark:text-white leading-none">VertooERP</span>
        <!-- Namensherkunft als Micro-Zeile: VER + TOO über Farbe UND Gewicht/Helligkeit abgesetzt -->
        <span class="mt-1 text-[10px] uppercase tracking-[0.22em] leading-none">
          <span class="font-extrabold text-brand-600 dark:text-brand-400">Ver</span><span class="font-medium text-gray-400 dark:text-gray-600">waltungs</span><span class="font-extrabold text-brand-600 dark:text-brand-400">too</span><span class="font-medium text-gray-400 dark:text-gray-600">l</span>
        </span>
      </span>
      <!-- Gestylter Tooltip statt nativem title-Attribut -->
      <span
        role="tooltip"
        class="pointer-events-none absolute left-0 top-full z-50 mt-2 whitespace-nowrap rounded-lg border border-gray-700 bg-gray-900 px-3 py-1.5 text-xs font-medium text-gray-100 shadow-lg opacity-0 translate-y-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-y-0 group-focus-visible:opacity-100 group-focus-visible:translate-y-0"
      >
        {lang === 'en'
          ? <>Vertoo = <span class="font-bold text-brand-400">Ver</span>waltungs<span class="font-bold text-brand-400">too</span>l — German for “management tool”</>
          : <>Vertoo steht für <span class="font-bold text-brand-400">Ver</span>waltungs<span class="font-bold text-brand-400">too</span>l</>}
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8" aria-label={t('a11y.nav.main')}>
      {navLinks.slice(0, 5).map((l) => (
        <a href={l.href} class="text-sm text-gray-600 dark:text-gray-300 hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href={localizePath('/#kontakt', lang)} class="hidden md:inline-flex text-sm text-gray-600 dark:text-gray-300 hover:text-brand-700 dark:hover:text-brand-400 transition-colors">{t('nav.contact')}</a>

      <div class="hidden sm:block"><LanguageSwitcher /></div>

      <button
        id="theme-toggle"
        type="button"
        aria-label={t('a11y.theme')}
        title={t('a11y.theme')}
        class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path stroke-linecap="round" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <a href="/konto" class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-brand-700 text-white text-sm font-medium hover:bg-brand-800 transition-colors">
        {t('nav.login')}
      </a>

      <!-- Hamburger (nur Mobile) -->
      <button
        id="menu-toggle"
        type="button"
        aria-label={t('a11y.menu.open')}
        data-label-open={t('a11y.menu.open')}
        data-label-close={t('a11y.menu.close')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 focus:outline-none focus:ring-2 focus:ring-brand-500 transition-colors"
      >
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile-Menü (Vollbild-Overlay unter dem Header) -->
  <nav
    id="mobile-menu"
    aria-label={t('a11y.nav.mobile')}
    class="hidden md:hidden fixed inset-x-0 top-16 z-40 h-[calc(100dvh-4rem)] bg-white dark:bg-gray-950 overflow-y-auto overscroll-contain"
  >
    <div class="flex flex-col min-h-full px-6 py-4">
      <ul class="flex-1 divide-y divide-gray-100 dark:divide-gray-800">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class="flex items-center justify-between py-4 text-lg font-medium text-gray-800 dark:text-gray-100 hover:text-brand-700 dark:hover:text-brand-400 transition-colors"
            >
              {l.label}
              <svg aria-hidden="true" class="w-5 h-5 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </li>
        ))}
      </ul>
      <div class="pt-6 pb-4 space-y-3">
        <a href={localizePath('/#kontakt', lang)} class="block w-full py-3.5 rounded-xl bg-brand-700 text-white font-semibold text-center hover:bg-brand-800 transition-colors">
          {t('cta.demo')}
        </a>
        <a href="/konto" class="block w-full py-3.5 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold text-center hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          {t('nav.login')}
        </a>
        <div class="pt-3 flex justify-center"><LanguageSwitcher /></div>
      </div>
    </div>
  </nav>
</header>

<script>
  // Theme-Toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try {
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    } catch (e) {}
  });

  // Mobile-Menü
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  const setMenu = (open: boolean) => {
    if (!mobileMenu || !menuToggle) return;
    mobileMenu.classList.toggle('hidden', !open);
    menuToggle.setAttribute('aria-expanded', String(open));
    menuToggle.setAttribute('aria-label', open ? (menuToggle.dataset.labelClose || 'Close menu') : (menuToggle.dataset.labelOpen || 'Open menu'));
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
    // Hintergrund-Scroll sperren, solange das Overlay offen ist
    document.body.style.overflow = open ? 'hidden' : '';
  };

  menuToggle?.addEventListener('click', () => {
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
    setMenu(!isOpen);
  });

  // Schließen bei Klick auf einen Link
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  // Schließen mit Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });
</script>
