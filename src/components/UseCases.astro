---
import { branchen } from '../data/branchen';

// Slug-Mapping: welche UseCase-Kacheln verlinken auf welche /branchen/-Seite?
// Wenn kein Slug → Kachel bleibt statisch (z.B. weil Branchen-Seite noch nicht existiert).
const slugBySlug = Object.fromEntries(branchen.map((b) => [b.slug, b.slug]));

const cases = [
  {
    title: 'E-Commerce & Handel',
    description: 'Warenwirtschaft, Paketierung, Preischeck und Dropshipping – alles für den Online- und Offline-Handel.',
    icon: '🛍',
    slug: slugBySlug.handel,
  },
  {
    title: 'Dienstleister & Agenturen',
    description: 'Zeiterfassung, Projektmanagement, Buchhaltung und Teamkommunikation für serviceorientierte Unternehmen.',
    icon: '💼',
    slug: undefined,
  },
  {
    title: 'Produktion & Logistik',
    description: 'Bestandsführung, Wareneingang, Versand-Tracking und Qualitätsprüfung für produzierende Betriebe.',
    icon: '🏭',
    slug: undefined,
  },
  {
    title: 'Handwerk & Bau',
    description: 'Betriebsmittel-Verwaltung, Fuhrpark, Kostenübersicht und mobile Zeiterfassung für Teams vor Ort.',
    icon: '🔧',
    slug: undefined,
  },
];
---

<section id="branchen" class="py-24 lg:py-32 bg-gray-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-700 uppercase tracking-wider">Branchen</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Für jede Branche die richtige Lösung</h2>
      <p class="mt-4 text-lg text-gray-500">
        Vertoo passt sich Ihrem Geschäft an – nicht umgekehrt.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {cases.map((c) => {
        const inner = (
          <>
            <span aria-hidden="true" class="text-4xl">{c.icon}</span>
            <h3 class="mt-4 text-xl font-semibold text-gray-900 flex items-center gap-2">
              {c.title}
              {c.slug && (
                <svg aria-hidden="true" class="w-4 h-4 text-brand-700 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </h3>
            <p class="mt-2 text-gray-500 leading-relaxed">{c.description}</p>
            {c.slug && (
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700">
                Mehr erfahren
                <svg aria-hidden="true" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            )}
          </>
        );
        return c.slug ? (
          <a href={`/branchen/${c.slug}`} class="group block p-8 rounded-2xl bg-white border border-gray-100 card-hover hover:border-brand-200 focus:outline-none focus:ring-2 focus:ring-brand-500">
            {inner}
          </a>
        ) : (
          <div class="group p-8 rounded-2xl bg-white border border-gray-100 card-hover">
            {inner}
          </div>
        );
      })}
    </div>
  </div>
</section>
