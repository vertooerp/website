---
import { Icon } from 'astro-icon/components';
import { branchen } from '../data/branchen';
import { getLangFromUrl, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);

// Slug-Mapping: welche UseCase-Kacheln verlinken auf welche /branchen/-Seite?
const slugBySlug = Object.fromEntries(branchen.map((b) => [b.slug, b.slug]));

const c = {
  de: {
    eyebrow: 'Branchen',
    heading: 'Für jede Branche die richtige Lösung',
    intro: 'Vertoo passt sich Ihrem Geschäft an – nicht umgekehrt.',
    more: 'Mehr erfahren',
    cases: [
      { title: 'E-Commerce & Handel', description: 'Warenwirtschaft, Paketierung, Preischeck und Dropshipping – alles für den Online- und Offline-Handel.' },
      { title: 'Dienstleister & Agenturen', description: 'Zeiterfassung, Projektmanagement, Buchhaltung und Teamkommunikation für serviceorientierte Unternehmen.' },
      { title: 'Produktion & Logistik', description: 'Bestandsführung, Wareneingang, Versand-Tracking und Qualitätsprüfung für produzierende Betriebe.' },
      { title: 'Handwerk & Bau', description: 'Betriebsmittel-Verwaltung, Fuhrpark, Kostenübersicht und mobile Zeiterfassung für Teams vor Ort.' },
    ],
  },
  en: {
    eyebrow: 'Industries',
    heading: 'The right solution for every industry',
    intro: 'Vertoo adapts to your business – not the other way around.',
    more: 'Learn more',
    cases: [
      { title: 'E-commerce & retail', description: 'Inventory management, packaging, price checks and dropshipping – everything for online and offline retail.' },
      { title: 'Service providers & agencies', description: 'Time tracking, project management, accounting and team communication for service-oriented companies.' },
      { title: 'Manufacturing & logistics', description: 'Stock control, goods receipt, shipment tracking and quality checks for manufacturing businesses.' },
      { title: 'Trades & construction', description: 'Equipment management, fleet, cost overview and mobile time tracking for teams on site.' },
    ],
  },
}[lang];

const icons = ['shopping-bag', 'briefcase', 'factory', 'wrench'];
const slugs = [slugBySlug.handel, slugBySlug.dienstleister, slugBySlug.produktion, slugBySlug.handwerk];
const cases = c.cases.map((cc, i) => ({ ...cc, icon: icons[i], slug: slugs[i] }));
---

<section id="branchen" class="py-24 lg:py-32 bg-gray-50 ">
  <div class="max-w-7xl mx-auto px-6">
    <div class="reveal text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{c.eyebrow}</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{c.heading}</h2>
      <p class="mt-4 text-lg text-gray-500 ">{c.intro}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {cases.map((cc) => {
        const inner = (
          <>
            <span aria-hidden="true" class="inline-flex text-brand-600 "><Icon name={`lucide:${cc.icon}`} class="w-9 h-9" /></span>
            <h3 class="mt-4 text-xl font-semibold text-gray-900  flex items-center gap-2">
              {cc.title}
              {cc.slug && (
                <svg aria-hidden="true" class="w-4 h-4 text-brand-700  opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </h3>
            <p class="mt-2 text-gray-500  leading-relaxed">{cc.description}</p>
            {cc.slug && (
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 ">
                {c.more}
                <svg aria-hidden="true" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            )}
          </>
        );
        return cc.slug ? (
          <a href={p(`/branchen/${cc.slug}`)} class="group block p-8 rounded-2xl bg-white  border border-gray-100  card-hover hover:border-brand-200  focus:outline-none focus:ring-2 focus:ring-brand-500">
            {inner}
          </a>
        ) : (
          <div class="group p-8 rounded-2xl bg-white  border border-gray-100  card-hover">
            {inner}
          </div>
        );
      })}
    </div>
  </div>
</section>
