---
---

<section id="kontakt" class="py-24 lg:py-32 bg-brand-700">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">Bereit, Ihre Prozesse zu digitalisieren?</h2>
    <p class="mt-4 text-lg text-white/90">
      Vereinbaren Sie eine unverbindliche Demo. Wir zeigen Ihnen, welche Module zu Ihrem Setup passen.
    </p>

    <div class="mt-10 bg-white rounded-2xl p-8 text-left shadow-xl shadow-brand-900/20">
      <form id="contact-form" class="space-y-4" action="/api/contact" method="POST" novalidate>
        <!-- Honeypot: vor Bots versteckt, vor Menschen aria-versteckt -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label>
            Website (bitte leer lassen)
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-vorname">Vorname *</label>
            <input id="contact-vorname" type="text" name="vorname" required autocomplete="given-name" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="Max" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-nachname">Nachname</label>
            <input id="contact-nachname" type="text" name="nachname" autocomplete="family-name" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="Mustermann" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-email">E-Mail *</label>
          <input id="contact-email" type="email" name="email" required autocomplete="email" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="max@firma.de" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-firma">Unternehmen</label>
          <input id="contact-firma" type="text" name="firma" autocomplete="organization" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500" placeholder="Firma GmbH" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="contact-nachricht">Nachricht (optional)</label>
          <textarea id="contact-nachricht" name="nachricht" rows="3" class="w-full px-4 py-3 rounded-xl bg-white border border-gray-300 text-gray-900 placeholder-gray-400 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 resize-none" placeholder="Welche Module interessieren Sie?"></textarea>
        </div>

        <!-- Status-/Fehler-Anzeige (aria-live damit Screenreader es ansagen) -->
        <div id="contact-status" role="status" aria-live="polite" class="hidden text-sm px-4 py-3 rounded-xl"></div>

        <button id="contact-submit" type="submit" class="w-full py-3.5 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 disabled:bg-gray-400 disabled:cursor-not-allowed transition-colors">
          Anfrage senden
        </button>
        <p class="text-xs text-gray-500 text-center">Wir melden uns innerhalb von 24 Stunden. Unverbindlich.</p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('contact-status') as HTMLDivElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  if (form && statusEl && submitBtn) {
    const setStatus = (kind: 'success' | 'error' | 'hidden', message = '') => {
      statusEl.classList.remove(
        'hidden',
        'bg-green-50', 'text-green-800', 'border', 'border-green-200',
        'bg-red-50', 'text-red-800', 'border-red-200'
      );
      if (kind === 'hidden') {
        statusEl.classList.add('hidden');
        statusEl.textContent = '';
        return;
      }
      if (kind === 'success') {
        statusEl.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200');
      } else {
        statusEl.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
      }
      statusEl.textContent = message;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      setStatus('hidden');

      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Wird gesendet…';

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });
        const data = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };

        if (res.ok && data.ok) {
          setStatus('success', 'Vielen Dank! Wir melden uns innerhalb von 24 Stunden.');
          form.reset();
        } else {
          setStatus('error', data.error || 'Es ist ein Fehler aufgetreten. Bitte später erneut versuchen.');
        }
      } catch {
        setStatus('error', 'Netzwerkfehler. Bitte Verbindung prüfen und erneut versuchen.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  }
</script>
