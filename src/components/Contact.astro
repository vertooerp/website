---
---

<section id="kontakt" class="py-24 lg:py-32 bg-brand-700">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">Bereit, Ihre Prozesse zu digitalisieren?</h2>
    <p class="mt-4 text-lg text-brand-100">
      Vereinbaren Sie eine unverbindliche Demo. Wir zeigen Ihnen, welche Module zu Ihrem Setup passen.
    </p>

    <div class="mt-10 bg-white/10 backdrop-blur-sm rounded-2xl p-8 text-left">
      <form class="space-y-4" action="mailto:kontakt@tapandtype.de" method="POST" enctype="text/plain">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-brand-100 mb-1" for="contact-vorname">Vorname</label>
            <input id="contact-vorname" type="text" name="vorname" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white placeholder-brand-200 text-sm focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="Max" />
          </div>
          <div>
            <label class="block text-sm font-medium text-brand-100 mb-1" for="contact-nachname">Nachname</label>
            <input id="contact-nachname" type="text" name="nachname" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white placeholder-brand-200 text-sm focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="Mustermann" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-100 mb-1" for="contact-email">E-Mail</label>
          <input id="contact-email" type="email" name="email" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white placeholder-brand-200 text-sm focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="max@firma.de" />
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-100 mb-1" for="contact-firma">Unternehmen</label>
          <input id="contact-firma" type="text" name="firma" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white placeholder-brand-200 text-sm focus:outline-none focus:ring-2 focus:ring-white/40" placeholder="Firma GmbH" />
        </div>
        <div>
          <label class="block text-sm font-medium text-brand-100 mb-1" for="contact-nachricht">Nachricht (optional)</label>
          <textarea id="contact-nachricht" name="nachricht" rows="3" class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/30 text-white placeholder-brand-200 text-sm focus:outline-none focus:ring-2 focus:ring-white/40 resize-none" placeholder="Welche Module interessieren Sie?"></textarea>
        </div>
        <button type="submit" class="w-full py-3.5 rounded-xl bg-white text-brand-700 font-semibold text-sm hover:bg-brand-50 transition-colors">
          Anfrage senden
        </button>
        <p class="text-xs text-brand-100 text-center">Wir melden uns innerhalb von 24 Stunden. Unverbindlich.</p>
      </form>
    </div>
  </div>
</section>
