---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, localizePath } from '../i18n/utils';
import { getBranchen } from '../data/localized';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const branchen = getBranchen(lang);

const s = {
  de: {
    title: 'Branchen – VertooERP',
    description: 'VertooERP für Ihre Branche: Handel & E-Commerce, Dienstleister & Agenturen, Produktion & Logistik sowie Handwerk & Bau – modulares ERP, self-gehostet.',
    eyebrow: 'Branchen', headline: 'Für Ihre Branche gedacht',
    intro: 'VertooERP passt sich Ihrem Geschäft an – nicht umgekehrt. Sehen Sie, welche Module für Ihre Branche zusammenspielen.',
  },
  en: {
    title: 'Industries – VertooERP',
    description: 'VertooERP for your industry: retail, e-commerce, service providers, manufacturing, logistics, trades and construction – modular, self-hosted ERP.',
    eyebrow: 'Industries', headline: 'Built for your industry',
    intro: 'VertooERP adapts to your business – not the other way around. See which modules work together for your industry.',
  },
}[lang];
---

<Layout title={s.title} description={s.description} hasTranslation>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-12 lg:pt-40 hero-gradient overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">{s.eyebrow}</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">{s.headline}</h1>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{s.intro}</p>
      </div>
    </section>

    <section class="py-12 lg:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {branchen.map((b) => (
            <a href={p(`/branchen/${b.slug}`)} class="group block p-8 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover hover:border-brand-200 dark:hover:border-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500">
              <div aria-hidden="true" class="w-12 h-12 rounded-xl bg-brand-50 dark:bg-gray-800 text-brand-600 dark:text-brand-400 flex items-center justify-center mb-4">
                <Icon name={`lucide:${b.icon}`} class="w-6 h-6" />
              </div>
              <h2 class="text-xl font-semibold text-gray-900 dark:text-white group-hover:text-brand-700 dark:group-hover:text-brand-400 transition-colors flex items-center gap-2">
                {b.name}
                <svg aria-hidden="true" class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </h2>
              <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">{b.metaDescription}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
