---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const sovereigntyHref = localizePath('/digitale-souveraenitaet', lang);
const sovereigntyLabel = lang === 'en' ? 'More on digital sovereignty' : 'Mehr zur digitalen Souveränität';

const c = {
  de: {
    eyebrow: 'Technologie & Sicherheit',
    heading: 'Gebaut für Vertrauen und digitale Souveränität',
    intro: 'Moderne Architektur, höchste Sicherheitsstandards, volle DSGVO-Konformität – und digitale Resilienz durch Self-Hosting: Ihre Kernprozesse laufen unabhängig von fremden Clouds.',
    features: [
      { title: 'Self-Hosting / On-Premises', description: 'Sie betreiben VertooERP auf eigener oder gemieteter Infrastruktur – volle Datenhoheit, kein Cloud-Zwang.' },
      { title: 'Session-basierte Auth', description: 'Sichere httpOnly Cookies statt Tokens. Kein localStorage-Risiko.' },
      { title: 'SSO mit Keycloak', description: 'Enterprise Single Sign-On für nahtlose Integration in Ihre IT-Landschaft.' },
      { title: 'PWA-fähig', description: 'Installierbar auf jedem Gerät. Kein App Store, kein Update-Zwang.' },
      { title: 'Multi-Tenant', description: 'Jeder Kunde bekommt eine eigene, isolierte Instanz mit eigenem Branding.' },
      { title: 'GoBD-konform', description: 'Unveränderbare Audit-Trails für Rechnungen und Finanzdaten.' },
    ],
  },
  en: {
    eyebrow: 'Technology & security',
    heading: 'Built for trust and digital sovereignty',
    intro: 'Modern architecture, the highest security standards, full GDPR compliance – and digital resilience through self-hosting: your core processes run independently of third-party clouds.',
    features: [
      { title: 'Self-hosting / on-premises', description: 'Run VertooERP on your own or rented infrastructure – full data sovereignty, no cloud lock-in.' },
      { title: 'Session-based auth', description: 'Secure httpOnly cookies instead of tokens. No localStorage risk.' },
      { title: 'SSO with Keycloak', description: 'Enterprise single sign-on for seamless integration into your IT landscape.' },
      { title: 'PWA-ready', description: 'Installable on any device. No app store, no forced updates.' },
      { title: 'Multi-tenant', description: 'Every customer gets their own isolated instance with custom branding.' },
      { title: 'GoBD-compliant', description: 'Immutable audit trails for invoices and financial data.' },
    ],
  },
}[lang];

const icons = ['server', 'lock', 'key-round', 'smartphone', 'building-2', 'clipboard-check'];
const features = c.features.map((f, i) => ({ ...f, icon: icons[i] }));
---

<section class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="reveal text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{c.eyebrow}</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{c.heading}</h2>
      <p class="mt-4 text-lg text-gray-500 ">{c.intro}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f) => (
        <div class="flex items-start gap-4 p-6 rounded-2xl border border-gray-100  bg-white  card-hover">
          <span aria-hidden="true" class="inline-flex text-brand-600  shrink-0"><Icon name={`lucide:${f.icon}`} class="w-6 h-6" /></span>
          <div>
            <h3 class="font-semibold text-gray-900 ">{f.title}</h3>
            <p class="mt-1 text-sm text-gray-500 ">{f.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href={sovereigntyHref} class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700  hover:text-brand-800  transition-colors">
        {sovereigntyLabel}
        <svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
      </a>
    </div>
  </div>
</section>
