---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { getCollection } from 'astro:content';
import { readingTimeMinutes } from '../utils/reading-time';
import { getLangFromUrl, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const p = (path: string) => localizePath(path, lang);
const cleanId = (id: string) => id.replace(/^en\//, '');

const posts = (await getCollection('blog', (e) => (e.data.lang ?? 'de') === lang)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const s = {
  de: {
    title: 'Blog – VertooERP',
    description: 'Fachartikel rund um ERP, Self-Hosting, Buchhaltung, GoBD und Digitalisierung für kleine und mittlere Unternehmen.',
    eyebrow: 'Blog', headline: 'Wissen für KMU',
    intro: 'Fachartikel zu ERP, Self-Hosting, Buchhaltung und Digitalisierung – praxisnah und ohne Marketing-Geschwätz.',
    locale: 'de-DE', readingTime: (n: number) => `${n} Min. Lesezeit`,
  },
  en: {
    title: 'Blog – VertooERP',
    description: 'Expert articles on ERP, self-hosting, accounting, GoBD and digitalisation for small and medium-sized enterprises.',
    eyebrow: 'Blog', headline: 'Knowledge for SMEs',
    intro: 'Expert articles on ERP, self-hosting, accounting and digitalisation – practical and without the marketing fluff.',
    locale: 'en-GB', readingTime: (n: number) => `${n} min read`,
  },
}[lang];

const dateFmt = (d: Date) => d.toLocaleDateString(s.locale, { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={s.title} description={s.description} hasTranslation>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-12 lg:pt-40 hero-gradient overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <span class="text-sm font-medium text-brand-700  uppercase tracking-wider">{s.eyebrow}</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">{s.headline}</h1>
        <p class="mt-4 text-lg text-gray-500 ">{s.intro}</p>
      </div>
    </section>

    <section class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <ul class="space-y-5">
          {posts.map((post) => (
            <li>
              <a href={p(`/blog/${cleanId(post.id)}`)} class="group block p-6 sm:p-8 rounded-2xl border border-gray-100  bg-white  card-hover hover:border-brand-200  focus:outline-none focus:ring-2 focus:ring-brand-500">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-brand-50  text-brand-700 ">{tag}</span>
                  ))}
                </div>
                <h2 class="text-xl sm:text-2xl font-bold text-gray-900  group-hover:text-brand-700  transition-colors">{post.data.title}</h2>
                <p class="mt-2 text-gray-600  leading-relaxed">{post.data.description}</p>
                <p class="mt-4 text-xs text-gray-500 ">
                  <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
                  <span class="mx-1.5" aria-hidden="true">·</span>
                  {s.readingTime(readingTimeMinutes(post.body ?? ''))}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
