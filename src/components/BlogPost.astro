---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { readingTimeMinutes } from '../utils/reading-time';
import type { Lang } from '../i18n/ui';
import { localizePath } from '../i18n/utils';

interface Props {
  post: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
  lang: Lang;
}

const { post, allPosts, lang } = Astro.props;
const { Content } = await render(post);
const p = (path: string) => localizePath(path, lang);
const cleanId = (id: string) => id.replace(/^en\//, '');

const minutes = readingTimeMinutes(post.body ?? '');

const related = allPosts
  .filter((pp) => pp.id !== post.id)
  .map((pp) => ({ post: pp, shared: pp.data.tags.filter((t) => post.data.tags.includes(t)).length }))
  .sort((a, b) => b.shared - a.shared || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime())
  .slice(0, 2)
  .map((x) => x.post);

const s = {
  de: {
    start: 'Start', blog: 'Blog', locale: 'de-DE',
    readingTime: (n: number) => `${n} Min. Lesezeit`,
    updated: (d: string) => `aktualisiert ${d}`,
    ctaHeading: 'VertooERP kennenlernen',
    ctaText: 'Modulares ERP, self-gehostet, DSGVO- und GoBD-konform. Vereinbaren Sie eine unverbindliche Demo.',
    ctaBtn: 'Demo anfragen', related: 'Verwandte Artikel',
    discover: 'Mehr entdecken', modules: 'Alle Module', industries: 'Branchen', glossary: 'ERP-Glossar',
  },
  en: {
    start: 'Home', blog: 'Blog', locale: 'en-GB',
    readingTime: (n: number) => `${n} min read`,
    updated: (d: string) => `updated ${d}`,
    ctaHeading: 'Discover VertooERP',
    ctaText: 'Modular ERP, self-hosted, GDPR- and GoBD-compliant. Book a no-obligation demo.',
    ctaBtn: 'Request a demo', related: 'Related articles',
    discover: 'Discover more', modules: 'All modules', industries: 'Industries', glossary: 'ERP glossary',
  },
}[lang];

const hubs = [
  { href: p('/module'), label: s.modules },
  { href: p('/branchen'), label: s.industries },
  { href: p('/glossar'), label: s.glossary },
];

const dateFmt = (d: Date) => d.toLocaleDateString(s.locale, { year: 'numeric', month: 'long', day: 'numeric' });

const siteUrl = 'https://vertoo.de';
const url = `${siteUrl}${p(`/blog/${cleanId(post.id)}`)}`;

const articleLd = {
  '@context': 'https://schema.org', '@type': 'BlogPosting',
  headline: post.data.title, description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  inLanguage: lang === 'en' ? 'en-GB' : 'de-DE',
  author: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)', url: siteUrl },
  publisher: { '@type': 'Organization', name: 'VertooERP', logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
};

const breadcrumbLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: s.start, item: `${siteUrl}${p('/')}` },
    { '@type': 'ListItem', position: 2, name: s.blog, item: `${siteUrl}${p('/blog')}` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<Layout title={post.data.title} description={post.data.description} jsonLd={[articleLd, breadcrumbLd]} hasTranslation>
  <Header />
  <main id="main-content">
    <article class="pt-32 pb-20 lg:pt-40">
      <div class="max-w-3xl mx-auto px-6">
        <nav aria-label="Breadcrumb" class="mb-8 text-sm text-gray-500 ">
          <a href={p('/')} class="hover:text-brand-700  transition-colors">{s.start}</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href={p('/blog')} class="hover:text-brand-700  transition-colors">{s.blog}</a>
        </nav>

        <div class="flex flex-wrap items-center gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-brand-50  text-brand-700 ">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 ">{post.data.title}</h1>
        <p class="mt-4 text-sm text-gray-500 ">
          <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
          <span class="mx-1.5" aria-hidden="true">·</span>
          {s.readingTime(minutes)}
          {post.data.updatedDate && (<span> · {s.updated(dateFmt(post.data.updatedDate))}</span>)}
        </p>

        <div class="prose prose-lg  mt-10 max-w-none prose-headings:font-bold prose-a:text-brand-700  prose-a:no-underline hover:prose-a:underline prose-th:text-left">
          <Content />
        </div>

        <div class="mt-14 rounded-2xl bg-brand-50  border border-brand-100  p-6 sm:p-8 text-center">
          <h2 class="text-xl font-bold text-gray-900 ">{s.ctaHeading}</h2>
          <p class="mt-2 text-sm text-gray-600 ">{s.ctaText}</p>
          <a href={p('/#kontakt')} class="mt-5 inline-flex items-center justify-center px-6 py-3 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 transition-colors">{s.ctaBtn}</a>
        </div>

        <!-- Interne Verlinkung: Hub-Seiten -->
        <nav aria-label={s.discover} class="mt-8 flex flex-wrap items-center gap-2.5">
          <span class="text-sm font-medium text-gray-500 ">{s.discover}:</span>
          {hubs.map((h) => (
            <a href={h.href} class="inline-flex items-center px-3.5 py-1.5 rounded-full text-sm font-medium border border-gray-200  text-gray-700  hover:border-brand-300 hover:text-brand-700  transition-colors">{h.label}</a>
          ))}
        </nav>

        {related.length > 0 && (
          <aside class="mt-14 border-t border-gray-100  pt-10">
            <h2 class="text-lg font-bold text-gray-900  mb-5">{s.related}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {related.map((r) => (
                <a href={p(`/blog/${cleanId(r.id)}`)} class="group block p-5 rounded-2xl border border-gray-100  bg-white  card-hover hover:border-brand-200  focus:outline-none focus:ring-2 focus:ring-brand-500">
                  <h3 class="font-semibold text-gray-900  group-hover:text-brand-700  transition-colors">{r.data.title}</h3>
                  <p class="mt-2 text-sm text-gray-600  leading-relaxed line-clamp-2">{r.data.description}</p>
                </a>
              ))}
            </div>
          </aside>
        )}
      </div>
    </article>
  </main>
  <Footer />
</Layout>
