---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import legal from '../data/_i18n-pending/legal.en.json';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const entry = legal.find((e) => e.slug === slug);
if (!entry) throw new Error(`Kein EN-Legal-Eintrag für "${slug}"`);

const baseTitle = entry.title.replace(/\s*[–-]\s*VertooERP\s*$/, '');
---

<Layout title={`${baseTitle} – VertooERP`} noindex={true} hasTranslation>
  <Header />
  <main id="main-content" class="pt-28 pb-20">
    <div class="max-w-3xl mx-auto px-6 legal-content" set:html={entry.contentHtml} />
  </main>
  <Footer />
</Layout>
