---
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const year = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-400 py-16 dark:border-t dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div aria-hidden="true" class="w-8 h-8 rounded-lg bg-brand-700 flex items-center justify-center">
            <span class="text-white font-bold text-sm">V</span>
          </div>
          <span class="flex flex-col justify-center">
            <span class="text-lg font-bold text-white leading-none">VertooERP</span>
            <!-- Namensherkunft: VER + TOO hervorgehoben (wie im Header) -->
            <span class="mt-1 text-[9px] font-semibold uppercase tracking-[0.22em] leading-none text-gray-500">
              <span class="text-brand-400">Ver</span>waltungs<span class="text-brand-400">too</span>l
            </span>
          </span>
        </div>
        <p class="text-sm leading-relaxed">{t('footer.tagline')}</p>
        <a href="mailto:kontakt@tapandtype.de" class="mt-4 inline-block text-sm text-gray-400 hover:text-white transition-colors">kontakt@tapandtype.de</a>
        <p class="mt-1 text-sm text-gray-500">Luckenwalde, Brandenburg</p>
      </div>

      <!-- Produkt -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t('footer.product')}</h3>
        <ul class="space-y-2.5">
          <li><a href={p('/#module')} class="text-sm hover:text-white transition-colors">{t('nav.module')}</a></li>
          <li><a href={p('/module')} class="text-sm hover:text-white transition-colors">{t('footer.moduleOverview')}</a></li>
          <li><a href={p('/alternativen')} class="text-sm hover:text-white transition-colors">{t('footer.compare')}</a></li>
          <li><a href={p('/digitale-souveraenitaet')} class="text-sm hover:text-white transition-colors">{t('footer.sovereignty')}</a></li>
          <li><a href={p('/#preise')} class="text-sm hover:text-white transition-colors">{t('nav.pricing')}</a></li>
          <li><a href={p('/#branchen')} class="text-sm hover:text-white transition-colors">{t('nav.industries')}</a></li>
          <li><a href={p('/blog')} class="text-sm hover:text-white transition-colors">{t('nav.blog')}</a></li>
          <li><a href={p('/glossar')} class="text-sm hover:text-white transition-colors">{t('footer.glossary')}</a></li>
          <li><a href={p('/#ablauf')} class="text-sm hover:text-white transition-colors">{t('nav.how')}</a></li>
        </ul>
      </div>

      <!--Unternehmen -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t('footer.company')}</h3>
        <ul class="space-y-2.5">
          <li><a href={p('/#kontakt')} class="text-sm hover:text-white transition-colors">{t('nav.contact')}</a></li>
          <li><a href={p('/impressum')} class="text-sm hover:text-white transition-colors">{t('footer.imprint')}</a></li>
          <li><a href={p('/barrierefreiheit')} class="text-sm hover:text-white transition-colors">{t('footer.accessibility')}</a></li>
          <li><a href={p('/datenschutz')} class="text-sm hover:text-white transition-colors">{t('footer.privacy')}</a></li>
        </ul>
      </div>

      <!-- Vertrauen / Trust -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">{t('footer.security')}</h3>
        <ul class="space-y-2.5">
          <li class="flex items-center gap-2.5">
            <svg aria-hidden="true" class="w-4 h-4 text-brand-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="7" rx="1.5" /><rect x="3" y="13" width="18" height="7" rx="1.5" /><path stroke-linecap="round" d="M7 7.5h.01M7 16.5h.01" /></svg>
            <span class="text-sm text-gray-300">{t('footer.trust.selfhosting')}</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg aria-hidden="true" class="w-4 h-4 text-brand-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2" /><path stroke-linecap="round" d="M8 11V7a4 4 0 1 1 8 0v4" /></svg>
            <span class="text-sm text-gray-300">{t('footer.trust.dsgvo')}</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg aria-hidden="true" class="w-4 h-4 text-brand-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.5 3h9l3.5 3.5v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" /></svg>
            <span class="text-sm text-gray-300">{t('footer.trust.gobd')}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs">&copy; {year} tap & type UG (haftungsbeschränkt). {t('footer.rights')}</p>
      <p class="text-xs">{t('footer.developed')} <span aria-hidden="true">🇪🇺</span> {t('footer.developed.in')} <span aria-hidden="true">🇩🇪</span></p>
    </div>
  </div>
</footer>
