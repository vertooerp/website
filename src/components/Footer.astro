---

<footer class="bg-gray-950 text-gray-400 py-16 dark:border-t dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div aria-hidden="true" class="w-8 h-8 rounded-lg bg-brand-700 flex items-center justify-center">
            <span class="text-white font-bold text-sm">V</span>
          </div>
          <span class="text-lg font-bold text-white">VertooERP</span>
        </div>
        <p class="text-sm leading-relaxed">Die modulare ERP-Plattform für moderne Unternehmen.</p>
      </div>

      <!-- Produkt -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Produkt</h3>
        <ul class="space-y-2">
          <li><a href="/#module" class="text-sm hover:text-white transition-colors">Module</a></li>
          <li><a href="/#preise" class="text-sm hover:text-white transition-colors">Preise</a></li>
          <li><a href="/#branchen" class="text-sm hover:text-white transition-colors">Branchen</a></li>
          <li><a href="/#ablauf" class="text-sm hover:text-white transition-colors">So funktioniert's</a></li>
        </ul>
      </div>

      <!--Unternehmen -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Unternehmen</h3>
        <ul class="space-y-2">
          <li><a href="/#kontakt" class="text-sm hover:text-white transition-colors">Kontakt</a></li>
          <li><a href="/impressum" class="text-sm hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/barrierefreiheit" class="text-sm hover:text-white transition-colors">Barrierefreiheit</a></li>
          <li><a href="/datenschutz" class="text-sm hover:text-white transition-colors">Datenschutz</a></li>
        </ul>
      </div>

      <!-- Vertrauen / Trust -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Vertrauen</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-3">
            <span aria-hidden="true" class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-900 border border-gray-800 text-base shrink-0">🇩🇪</span>
            <span class="text-sm text-gray-300">Hosting in Deutschland</span>
          </li>
          <li class="flex items-center gap-3">
            <span aria-hidden="true" class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-900 border border-gray-800 shrink-0">
              <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="10" rx="2" /><path stroke-linecap="round" d="M8 11V7a4 4 0 1 1 8 0v4" /></svg>
            </span>
            <span class="text-sm text-gray-300">100&nbsp;% DSGVO-konform</span>
          </li>
          <li class="flex items-center gap-3">
            <span aria-hidden="true" class="flex items-center justify-center w-8 h-8 rounded-lg bg-gray-900 border border-gray-800 shrink-0">
              <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z" /></svg>
            </span>
            <span class="text-sm text-gray-300">Keine US-Cloud</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs">&copy; {new Date().getFullYear()} tap & type UG (haftungsbeschränkt). Alle Rechte vorbehalten.</p>
      <p class="text-xs">Entwickelt in Brandenburg <span aria-hidden="true">🇩🇪</span></p>
    </div>
  </div>
</footer>
