---
---

<footer class="bg-gray-950 text-gray-400 py-16">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-brand-700 flex items-center justify-center">
            <span class="text-white font-bold text-sm">V</span>
          </div>
          <span class="text-lg font-bold text-white">Vertoo</span>
        </div>
        <p class="text-sm leading-relaxed">Die modulare ERP-Plattform für moderne Unternehmen.</p>
      </div>

      <!-- Produkt -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Produkt</h4>
        <ul class="space-y-2">
          <li><a href="#module" class="text-sm hover:text-white transition-colors">Module</a></li>
          <li><a href="#preise" class="text-sm hover:text-white transition-colors">Preise</a></li>
          <li><a href="#branchen" class="text-sm hover:text-white transition-colors">Branchen</a></li>
          <li><a href="#ablauf" class="text-sm hover:text-white transition-colors">So funktioniert's</a></li>
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Unternehmen</h4>
        <ul class="space-y-2">
          <li><a href="#kontakt" class="text-sm hover:text-white transition-colors">Kontakt</a></li>
          <li><a href="/impressum" class="text-sm hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/barrierefreiheit" class="text-sm hover:text-white transition-colors">Barrierefreiheit</a></li>
          <li><a href="/datenschutz" class="text-sm hover:text-white transition-colors">Datenschutz</a></li>
        </ul>
      </div>

      <!-- Partner -->
      <div>
        <h4 class="text-sm font-semibold text-white mb-4">Partner</h4>
        <div class="flex flex-col gap-4">
          <a href="https://scholtopia.de/" target="_blank" rel="noopener">
            <img src="/images/scholtopia.png" alt="Scholtopia" class="h-6 w-auto opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all" />
          </a>
          <a href="https://www.hetzner.com/de/" target="_blank" rel="noopener">
            <img src="/images/hetzner.png" alt="Hetzner" class="h-6 w-auto opacity-50 grayscale hover:opacity-100 hover:grayscale-0 transition-all" />
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs">&copy; {new Date().getFullYear()} tap & type UG (haftungsbeschränkt). Alle Rechte vorbehalten.</p>
      <p class="text-xs">Entwickelt und gehostet in Deutschland <span aria-hidden="true">🇩🇪</span></p>
    </div>
  </div>
</footer>
