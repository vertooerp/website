---
---

<section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 hero-gradient overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="max-w-3xl mx-auto text-center">
      <div class="animate-fade-up">
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
          Modulare Business-Plattform
        </span>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight animate-fade-up">
        Schluss mit <span class="gradient-text">Excel-Chaos</span><br />
        und Tool-Wirrwarr.
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-gray-500 leading-relaxed animate-fade-up-delay max-w-2xl mx-auto">
        Statt zehn verschiedene Tools zu jonglieren, vereint VertooERP Zeiterfassung, Warenwirtschaft, Buchhaltung, Aufgaben und Kommunikation in einer einzigen Plattform – entwickelt und gehostet in Deutschland.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up-delay-2">
        <a href="#kontakt" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-brand-700 text-white font-semibold hover:bg-brand-800 transition-all hover:shadow-lg hover:shadow-brand-700/25 text-center">
          Demo anfragen
        </a>
        <a href="#module" class="w-full sm:w-auto px-8 py-3.5 rounded-xl border border-gray-200 text-gray-700 font-semibold hover:bg-gray-50 transition-colors text-center">
          Module entdecken
        </a>
      </div>

      <p class="mt-4 text-xs text-gray-500">Persönliche Beratung · Individuelle Konditionen · Hosting in Deutschland</p>
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-brand-200/20 rounded-full blur-3xl -z-10 animate-float"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-brand-300/10 rounded-full blur-3xl -z-10" style="animation: float 8s ease-in-out infinite 2s;"></div>
  </div>

  <!-- App preview mockup (rein dekorativ) -->
  <div aria-hidden="true" class="max-w-5xl mx-auto mt-16 px-6 animate-fade-up-delay-2">
    <div class="relative rounded-2xl border border-gray-200 bg-white shadow-2xl shadow-gray-200/50 overflow-hidden">
      <!-- Browser chrome -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-100 bg-gray-50/50">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-400"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
          <div class="w-3 h-3 rounded-full bg-green-400"></div>
        </div>
        <div class="flex-1 flex justify-center">
          <div class="px-4 py-1 rounded-md bg-gray-100 text-xs text-gray-600">app.vertoo.de</div>
        </div>
      </div>
      <!-- App content placeholder -->
      <div class="aspect-[16/9] bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center">
        <div class="flex items-start gap-0 w-full h-full">
          <!-- Sidebar mockup -->
          <div class="w-56 h-full bg-white border-r border-gray-100 p-4 hidden sm:block">
            <div class="flex items-center gap-2 mb-6">
              <div class="w-6 h-6 rounded-md bg-brand-700"></div>
              <div class="h-4 w-24 bg-gray-200 rounded"></div>
            </div>
            <div class="space-y-2">
              <div class="h-8 bg-brand-50 rounded-lg"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
              <div class="mt-4 h-3 w-16 bg-gray-100 rounded"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
              <div class="mt-4 h-3 w-20 bg-gray-100 rounded"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
              <div class="h-8 bg-gray-50 rounded-lg"></div>
            </div>
          </div>
          <!-- Main content mockup -->
          <div class="flex-1 p-6 sm:p-8">
            <div class="h-6 w-40 bg-gray-200 rounded mb-6"></div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
              <div class="h-20 bg-white rounded-xl border border-gray-100 shadow-sm"></div>
              <div class="h-20 bg-white rounded-xl border border-gray-100 shadow-sm"></div>
              <div class="h-20 bg-white rounded-xl border border-gray-100 shadow-sm hidden sm:block"></div>
              <div class="h-20 bg-white rounded-xl border border-gray-100 shadow-sm hidden sm:block"></div>
            </div>
            <div class="h-48 bg-white rounded-xl border border-gray-100 shadow-sm"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
