---
import { testimonials, customerLogos } from '../data/testimonials';

// Rendert nur, wenn echte Referenzen hinterlegt sind (siehe testimonials.ts).
const hasLogos = customerLogos.length > 0;
const hasQuotes = testimonials.length > 0;
const show = hasLogos || hasQuotes;
---

{show && (
  <section id="referenzen" class="py-20 lg:py-28 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Referenzen</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Unternehmen, die auf VertooERP setzen</h2>
      </div>

      {hasLogos && (
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 mb-16">
          {customerLogos.map((logo) => (
            <a href={logo.url} target={logo.url ? '_blank' : undefined} rel={logo.url ? 'noopener' : undefined} class="block">
              <img src={logo.src} alt={logo.name} class="h-7 w-auto opacity-60 grayscale hover:opacity-100 hover:grayscale-0 transition-all dark:invert dark:opacity-70" loading="lazy" />
            </a>
          ))}
        </div>
      )}

      {hasQuotes && (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.map((tRef) => (
            <figure class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 flex flex-col">
              <svg aria-hidden="true" class="w-8 h-8 text-brand-200 dark:text-brand-700 mb-3" fill="currentColor" viewBox="0 0 24 24"><path d="M9.5 7A4.5 4.5 0 0 0 5 11.5V17h5v-5H7.5A2.5 2.5 0 0 1 10 9.5V7H9.5zm9 0A4.5 4.5 0 0 0 14 11.5V17h5v-5h-2.5A2.5 2.5 0 0 1 19 9.5V7h-.5z"/></svg>
              <blockquote class="flex-1 text-gray-700 dark:text-gray-200 leading-relaxed">{tRef.quote}</blockquote>
              <figcaption class="mt-4 text-sm">
                <span class="font-semibold text-gray-900 dark:text-white">{tRef.author}</span>
                <span class="block text-gray-500 dark:text-gray-400">{tRef.role}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      )}
    </div>
  </section>
)}
