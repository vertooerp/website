---
import { Icon } from 'astro-icon/components';

const plans = [
  {
    name: 'Starter',
    price: '350',
    period: 'pro Monat',
    modulRange: 'Bis zu 3 Module',
    seats: '3 Seats inklusive',
    extraSeat: '+18 € je weiterer Seat',
    description: 'Für kleine Teams, die mit einzelnen Modulen gezielt starten.',
    features: [
      'Bis zu 3 wählbare Module',
      '3 Seats inklusive (+18 € / weiterer Seat)',
      'Multi-Standort & Multi-Mandant',
      'PWA (mobil installierbar)',
      'E-Mail-Support',
    ],
    cta: 'Starter anfragen',
    highlight: false,
  },
  {
    name: 'Business',
    price: '800',
    period: 'pro Monat',
    modulRange: 'Bis zu 12 Module',
    seats: '10 Seats inklusive',
    extraSeat: '+22 € je weiterer Seat',
    description: 'Für wachsende Unternehmen mit breitem Funktionsumfang.',
    features: [
      'Bis zu 12 Module frei kombinierbar',
      '10 Seats inklusive (+22 € / weiterer Seat)',
      'Multi-Standort & Multi-Mandant',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Prioritäts-Support',
    ],
    cta: 'Business anfragen',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: '1.400',
    period: 'pro Monat',
    modulRange: 'Alle 20+ Module',
    seats: '20 Seats inklusive',
    extraSeat: '+28 € je weiterer Seat',
    description: 'Für große Organisationen, die das volle Spektrum nutzen.',
    features: [
      'Alle 20+ Module',
      '20 Seats inklusive (+28 € / weiterer Seat)',
      'Multi-Standort & Multi-Mandant',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Custom Branding',
      'Dedizierter Ansprechpartner',
      'SLA & Onboarding',
    ],
    cta: 'Kontakt aufnehmen',
    highlight: false,
  },
];

// Detaillierte Feature-Matrix (Starter / Business / Enterprise)
// Wert true = enthalten, false = nicht enthalten, sonst Text.
const featureMatrix = [
  { label: 'Module', values: ['bis 3', 'bis 12', 'alle 20+'] },
  { label: 'Seats inklusive', values: ['3', '10', '20'] },
  { label: 'Aufpreis je weiterer Seat', values: ['18 €', '22 €', '28 €'] },
  { label: 'Multi-Standort & Multi-Mandant', values: [true, true, true] },
  { label: 'PWA (mobil installierbar)', values: [true, true, true] },
  { label: 'Keycloak SSO', values: [false, true, true] },
  { label: 'Custom Branding', values: [false, false, true] },
  { label: 'Support', values: ['E-Mail', 'Priorität', 'Dediziert'] },
  { label: 'SLA & Onboarding', values: [false, false, true] },
];
const tiers = ['Starter', 'Business', 'Enterprise'];
---

<section id="preise" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="reveal text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Preise</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Transparent und fair</h2>
      <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
        Die Stufe richtet sich nach der Anzahl der von Ihnen genutzten Module. Alle Preise zzgl. MwSt., Mindestlaufzeit 12 Monate.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-8 ${plan.highlight ? 'bg-brand-700 text-white ring-2 ring-brand-700 scale-105' : 'bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800'}`}>
          {plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-amber-400 text-amber-900 text-xs font-semibold shadow-md">
              Beliebteste Wahl
            </div>
          )}
          <h3 class={`text-xl font-bold ${plan.highlight ? 'text-white' : 'text-gray-900 dark:text-white'}`}>{plan.name}</h3>
          <p class={`mt-1 text-sm font-medium ${plan.highlight ? 'text-brand-100' : 'text-brand-700 dark:text-brand-400'}`}>{plan.modulRange}</p>
          <p class={`mt-1 text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-500 dark:text-gray-400'}`}>{plan.description}</p>

          <div class="mt-6 flex items-baseline gap-1">
            <span class={`text-4xl font-extrabold ${plan.highlight ? 'text-white' : 'text-gray-900 dark:text-white'}`}>{plan.price} €</span>
            <span class={`text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-500 dark:text-gray-400'}`}>{plan.period}</span>
          </div>
          <p class={`mt-1 text-xs ${plan.highlight ? 'text-brand-100' : 'text-gray-500 dark:text-gray-400'}`}>{plan.seats} · {plan.extraSeat}</p>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg aria-hidden="true" class={`w-5 h-5 shrink-0 mt-0.5 ${plan.highlight ? 'text-brand-100' : 'text-brand-700 dark:text-brand-400'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class={`text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-600 dark:text-gray-300'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#kontakt"
            class={`mt-8 block w-full py-3 rounded-xl text-center font-semibold text-sm transition-colors ${
              plan.highlight
                ? 'bg-white text-brand-700 hover:bg-brand-50'
                : 'bg-brand-700 text-white hover:bg-brand-800'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Detaillierte Feature-Vergleichstabelle -->
    <details class="group mt-12 max-w-4xl mx-auto rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 overflow-hidden">
      <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold text-gray-900 dark:text-white list-none [&::-webkit-details-marker]:hidden">
        <span>Alle Funktionen im Vergleich</span>
        <svg aria-hidden="true" class="w-5 h-5 text-brand-700 dark:text-brand-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="overflow-x-auto border-t border-gray-100 dark:border-gray-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-100 dark:border-gray-800">
              <th scope="col" class="text-left font-medium text-gray-500 dark:text-gray-400 px-6 py-3">Funktion</th>
              {tiers.map((t) => (
                <th scope="col" class="text-center font-semibold text-gray-900 dark:text-white px-4 py-3 min-w-[100px]">{t}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {featureMatrix.map((row, i) => (
              <tr class={i % 2 === 1 ? 'bg-gray-50/60 dark:bg-gray-800/40' : ''}>
                <th scope="row" class="text-left font-medium text-gray-700 dark:text-gray-300 px-6 py-3">{row.label}</th>
                {row.values.map((v) => (
                  <td class="text-center px-4 py-3">
                    {v === true ? (
                      <span class="inline-flex text-brand-600 dark:text-brand-400" title="enthalten">
                        <svg aria-label="enthalten" role="img" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      </span>
                    ) : v === false ? (
                      <span class="text-gray-300 dark:text-gray-600" aria-label="nicht enthalten">–</span>
                    ) : (
                      <span class="text-gray-700 dark:text-gray-300">{v}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </details>

    <!-- Sonderkondition: Ergänzend zu bestehendem System -->
    <div class="mt-12 max-w-3xl mx-auto">
      <div class="rounded-2xl border border-brand-100 dark:border-brand-900/50 bg-brand-50/40 dark:bg-brand-950/30 p-6 sm:p-8 flex flex-col sm:flex-row items-start gap-5">
        <div aria-hidden="true" class="w-12 h-12 rounded-xl bg-white dark:bg-gray-800 border border-brand-100 dark:border-gray-700 flex items-center justify-center text-brand-600 dark:text-brand-400 shrink-0">
          <Icon name="lucide:link" class="w-6 h-6" />
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Ergänzend zu bestehendem System?</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
            Wenn Sie VertooERP <strong>ergänzend</strong> zu einem bereits führenden System (z.&nbsp;B. JTL-Wawi, SAP, DATEV) einsetzen wollen, gewähren wir einen <strong>deutlichen Abschlag</strong> auf die Grundgebühr. Wir kalkulieren individuell passend zu Ihrem Setup.
          </p>
          <a href="#kontakt" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 dark:text-brand-400 hover:text-brand-800 dark:hover:text-brand-300 transition-colors">
            Konditionen anfragen
            <svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Footnote: weitere Vertragsdetails -->
    <p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-400 max-w-3xl mx-auto leading-relaxed">
      Mindestlaufzeit 12 Monate · Kündigungsfrist 3 Monate · Hosting, Einrichtung, Wartung und Support nicht inklusive (separat buchbar)
    </p>
  </div>
</section>
