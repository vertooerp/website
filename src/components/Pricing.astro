---
const plans = [
  {
    name: 'Starter',
    price: '350',
    period: 'pro Monat',
    modulRange: 'Bis zu 3 Module',
    seats: '3 Seats inklusive',
    extraSeat: '+18 € je weiterer Seat',
    description: 'Für kleine Teams, die mit einzelnen Modulen gezielt starten.',
    features: [
      'Bis zu 3 wählbare Module',
      '3 Seats inklusive (+18 € / weiterer Seat)',
      'Multi-Standort',
      'PWA (mobil installierbar)',
      'E-Mail-Support',
    ],
    cta: 'Starter anfragen',
    highlight: false,
  },
  {
    name: 'Business',
    price: '800',
    period: 'pro Monat',
    modulRange: 'Bis zu 12 Module',
    seats: '10 Seats inklusive',
    extraSeat: '+22 € je weiterer Seat',
    description: 'Für wachsende Unternehmen mit breitem Funktionsumfang.',
    features: [
      'Bis zu 12 Module frei kombinierbar',
      '10 Seats inklusive (+22 € / weiterer Seat)',
      'Multi-Standort',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Prioritäts-Support',
    ],
    cta: 'Business anfragen',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: '1.400',
    period: 'pro Monat',
    modulRange: 'Alle 20+ Module',
    seats: '20 Seats inklusive',
    extraSeat: '+28 € je weiterer Seat',
    description: 'Für große Organisationen, die das volle Spektrum nutzen.',
    features: [
      'Alle 20+ Module',
      '20 Seats inklusive (+28 € / weiterer Seat)',
      'Multi-Standort & Multi-Tenant',
      'PWA (mobil installierbar)',
      'Keycloak SSO',
      'Custom Branding',
      'Dedizierter Ansprechpartner',
      'SLA & Onboarding',
    ],
    cta: 'Kontakt aufnehmen',
    highlight: false,
  },
];
---

<section id="preise" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-medium text-brand-600 uppercase tracking-wider">Preise</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Transparent und fair</h2>
      <p class="mt-4 text-lg text-gray-500">
        Die Stufe richtet sich nach der Anzahl der von Ihnen genutzten Module. Alle Preise zzgl. MwSt., Mindestlaufzeit 12 Monate.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {plans.map((plan) => (
        <div class={`relative rounded-2xl p-8 ${plan.highlight ? 'bg-brand-700 text-white ring-2 ring-brand-700 scale-105' : 'bg-white border border-gray-200'}`}>
          {plan.highlight && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full bg-brand-500 text-white text-xs font-medium">
              Beliebteste Wahl
            </div>
          )}
          <h3 class={`text-xl font-bold ${plan.highlight ? 'text-white' : 'text-gray-900'}`}>{plan.name}</h3>
          <p class={`mt-1 text-sm font-medium ${plan.highlight ? 'text-brand-200' : 'text-brand-600'}`}>{plan.modulRange}</p>
          <p class={`mt-1 text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-500'}`}>{plan.description}</p>

          <div class="mt-6 flex items-baseline gap-1">
            <span class={`text-4xl font-extrabold ${plan.highlight ? 'text-white' : 'text-gray-900'}`}>{plan.price} €</span>
            <span class={`text-sm ${plan.highlight ? 'text-brand-200' : 'text-gray-400'}`}>{plan.period}</span>
          </div>
          <p class={`mt-1 text-xs ${plan.highlight ? 'text-brand-200' : 'text-gray-400'}`}>{plan.seats} · {plan.extraSeat}</p>

          <ul class="mt-8 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class={`w-5 h-5 shrink-0 mt-0.5 ${plan.highlight ? 'text-brand-200' : 'text-brand-600'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class={`text-sm ${plan.highlight ? 'text-brand-100' : 'text-gray-600'}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#kontakt"
            class={`mt-8 block w-full py-3 rounded-xl text-center font-semibold text-sm transition-colors ${
              plan.highlight
                ? 'bg-white text-brand-700 hover:bg-brand-50'
                : 'bg-brand-700 text-white hover:bg-brand-800'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Sonderkondition: Ergänzend zu bestehendem System -->
    <div class="mt-12 max-w-3xl mx-auto">
      <div class="rounded-2xl border border-brand-100 bg-brand-50/40 p-6 sm:p-8 flex flex-col sm:flex-row items-start gap-5">
        <div class="w-12 h-12 rounded-xl bg-white border border-brand-100 flex items-center justify-center text-2xl shrink-0">
          🔗
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-gray-900">Ergänzend zu bestehendem System?</h3>
          <p class="mt-2 text-sm text-gray-600 leading-relaxed">
            Wenn Sie VertooERP <strong>ergänzend</strong> zu einem bereits führenden System (z.&nbsp;B. JTL-Wawi, SAP, DATEV) einsetzen wollen, gewähren wir einen <strong>deutlichen Abschlag</strong> auf die Grundgebühr. Wir kalkulieren individuell passend zu Ihrem Setup.
          </p>
          <a href="#kontakt" class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 hover:text-brand-800 transition-colors">
            Konditionen anfragen
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Footnote: weitere Vertragsdetails -->
    <p class="mt-8 text-center text-xs text-gray-400 max-w-3xl mx-auto leading-relaxed">
      Mindestlaufzeit 12 Monate · Kündigungsfrist 3 Monate · Jährliche Preisanpassung 4 % ab dem zweiten Vertragsjahr · Hosting, Einrichtung, Wartung und Support nicht inklusive (separat buchbar)
    </p>
  </div>
</section>
