---
import '../styles/global.css';
import '@fontsource-variable/inter';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'VertooERP – Die modulare Business-Plattform',
  description = 'Modulares ERP für KMU mit 20+ Modulen: Buchhaltung, Warenwirtschaft, Lager, Aufgaben, KI und mehr – alles in einer Plattform aus Deutschland.',
  noindex = false,
  image = '/og-image.png',
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://vertoo.de');
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const imageURL = new URL(image, siteUrl).toString();

// Default Organization schema, always present
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'VertooERP',
  legalName: 'tap & type UG (haftungsbeschränkt)',
  url: siteUrl.toString(),
  logo: new URL('/favicon.svg', siteUrl).toString(),
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Pestalozzistr. 14',
    postalCode: '14943',
    addressLocality: 'Luckenwalde',
    addressCountry: 'DE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'kontakt@tapandtype.de',
    telephone: '+49-15678-618781',
    areaServed: 'DE',
    availableLanguage: 'de',
  },
};

const ldScripts = [organizationLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <!-- Theme früh setzen, bevor der Body rendert (kein FOUC) -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VertooERP" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="VertooERP – Die modulare Business-Plattform" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <title>{title}</title>

    {ldScripts.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-brand-700 focus:text-white focus:font-medium focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-300"
    >
      Zum Hauptinhalt springen
    </a>
    <slot />
  </body>
</html>
