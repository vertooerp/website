---
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
// Preload der Latin-Subsets (LCP): ?url liefert dieselbe gehashte Asset-URL,
// die auch das Fontsource-CSS referenziert (Vite content-hashing).
import interLatinUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import spaceGroteskLatinUrl from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2?url';
import { getLangFromUrl, stripLangFromPath, localizePath, useTranslations } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** true, wenn diese Seite in beiden Sprachen existiert → hreflang + Sprachumschalter */
  hasTranslation?: boolean;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const defaultMeta = {
  de: {
    title: 'VertooERP – Das modulare All-in-One-ERP für den Mittelstand',
    description: 'All-in-One-ERP für KMU: 20+ Module von Buchhaltung bis Warenwirtschaft, DSGVO- und GoBD-konform, Self-Hosting – entwickelt in Deutschland für Europa.',
  },
  en: {
    title: 'VertooERP – The modular all-in-one ERP for SMEs',
    description: 'All-in-one ERP for SMEs: 20+ modules from accounting to inventory, GDPR- and GoBD-compliant, self-hosted – built in Germany for Europe.',
  },
} as const;

const {
  title = defaultMeta[lang].title,
  description = defaultMeta[lang].description,
  noindex = false,
  image = '/og-image.png',
  jsonLd,
  hasTranslation = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://vertoo.de');
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const imageURL = new URL(image, siteUrl).toString();

// hreflang-Alternates nur, wenn die Seite wirklich in beiden Sprachen existiert.
// URLs mit Trailing-Slash normalisieren, damit sie exakt zum (directory-)Canonical passen.
const basePath = stripLangFromPath(Astro.url.pathname);
const altUrl = (lang: 'de' | 'en') => {
  const u = new URL(localizePath(basePath, lang), siteUrl);
  if (!u.pathname.endsWith('/')) u.pathname += '/';
  return u.toString();
};
const alternates = hasTranslation
  ? [
      { hreflang: 'de', href: altUrl('de') },
      { hreflang: 'en', href: altUrl('en') },
      { hreflang: 'x-default', href: altUrl(defaultLang) },
    ]
  : [];

// Cloudflare Web Analytics (cookielos). Token als Env-Var in CF Pages setzen:
//   PUBLIC_CF_ANALYTICS_TOKEN=<token aus dem CF-Dashboard>
// Alternativ kann Web Analytics im CF-Pages-Dashboard per Toggle auto-injiziert
// werden – dann ist diese Variable nicht nötig (der CSP erlaubt beides).
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// Default Organization schema, always present
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'VertooERP',
  legalName: 'tap & type UG (haftungsbeschränkt)',
  url: siteUrl.toString(),
  logo: new URL('/favicon.svg', siteUrl).toString(),
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Pestalozzistr. 14',
    postalCode: '14943',
    addressLocality: 'Luckenwalde',
    addressCountry: 'DE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'kontakt@tapandtype.de',
    telephone: '+49-15678-618781',
    areaServed: ['DE', 'AT', 'CH', 'EU'],
    availableLanguage: ['de', 'en'],
  },
};

// WebSite-Schema, sitewide – Sprache passt sich der aktuellen Seite an.
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VertooERP',
  url: siteUrl.toString(),
  inLanguage: lang === 'en' ? 'en-GB' : 'de-DE',
  publisher: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)' },
};

const ldScripts = [organizationLd, websiteLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <!-- Theme + js-Klasse früh setzen, bevor der Body rendert (kein FOUC) -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js');
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" as="font" type="font/woff2" href={interLatinUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={spaceGroteskLatinUrl} crossorigin />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/icon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#047857" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#030712" media="(prefers-color-scheme: dark)" />
    <link rel="alternate" type="application/rss+xml" title="VertooERP Blog" href="/rss.xml" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VertooERP" />
    <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'de_DE'} />
    {hasTranslation && <meta property="og:locale:alternate" content={lang === 'en' ? 'de_DE' : 'en_GB'} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={lang === 'en' ? 'VertooERP – The modular business platform' : 'VertooERP – Die modulare Business-Plattform'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <title>{title}</title>

    {ldScripts.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
      />
    )}
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-brand-700 focus:text-white focus:font-medium focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-300"
    >
      {t('a11y.skip')}
    </a>
    <slot />

    <script>
      // Scroll-Reveal via IntersectionObserver
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (els.length && !prefersReduced && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        // Fallback: sofort sichtbar
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
