---
import '../styles/global.css';
import '@fontsource-variable/inter';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'VertooERP – Modulares ERP für den Mittelstand',
  description = 'Modulares ERP für KMU mit 20+ Modulen: Buchhaltung, Warenwirtschaft, Lager, Aufgaben, KI und mehr – alles in einer Plattform aus Deutschland.',
  noindex = false,
  image = '/og-image.png',
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://vertoo.de');
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const imageURL = new URL(image, siteUrl).toString();

// Cloudflare Web Analytics (cookielos). Token als Env-Var in CF Pages setzen:
//   PUBLIC_CF_ANALYTICS_TOKEN=<token aus dem CF-Dashboard>
// Alternativ kann Web Analytics im CF-Pages-Dashboard per Toggle auto-injiziert
// werden – dann ist diese Variable nicht nötig (der CSP erlaubt beides).
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;

// Default Organization schema, always present
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'VertooERP',
  legalName: 'tap & type UG (haftungsbeschränkt)',
  url: siteUrl.toString(),
  logo: new URL('/favicon.svg', siteUrl).toString(),
  description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Pestalozzistr. 14',
    postalCode: '14943',
    addressLocality: 'Luckenwalde',
    addressCountry: 'DE',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    email: 'kontakt@tapandtype.de',
    telephone: '+49-15678-618781',
    areaServed: 'DE',
    availableLanguage: 'de',
  },
};

// WebSite-Schema, sitewide
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'VertooERP',
  url: siteUrl.toString(),
  inLanguage: 'de-DE',
  publisher: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)' },
};

const ldScripts = [organizationLd, websiteLd, ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <!-- Theme + js-Klasse früh setzen, bevor der Body rendert (kein FOUC) -->
    <script is:inline>
      (function () {
        document.documentElement.classList.add('js');
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (!stored && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/icon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#047857" />
    <link rel="alternate" type="application/rss+xml" title="VertooERP Blog" href="/rss.xml" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="VertooERP" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="VertooERP – Die modulare Business-Plattform" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <title>{title}</title>

    {ldScripts.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {cfAnalyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cfAnalyticsToken })}
      />
    )}
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-950 dark:text-gray-100 font-sans antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-brand-700 focus:text-white focus:font-medium focus:rounded-lg focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-brand-300"
    >
      Zum Hauptinhalt springen
    </a>
    <slot />

    <script>
      // Scroll-Reveal via IntersectionObserver
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (els.length && !prefersReduced && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                obs.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        // Fallback: sofort sichtbar
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
