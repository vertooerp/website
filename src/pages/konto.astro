---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Anmelden – VertooERP" description="Melden Sie sich bei VertooERP an" noindex={true}>
  <main id="main-content" class="min-h-screen bg-gray-50 dark:bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2.5">
          <div aria-hidden="true" class="w-10 h-10 rounded-xl bg-brand-700 flex items-center justify-center">
            <span class="text-white font-bold text-lg">V</span>
          </div>
          <span class="text-2xl font-bold text-gray-900 dark:text-white">VertooERP</span>
        </a>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Melden Sie sich in Ihrem Konto an</p>
      </div>

      <!-- Login Card -->
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-lg shadow-gray-200/50 dark:shadow-black/40 border border-gray-200 dark:border-gray-800 p-8">
        <form class="space-y-5" onsubmit="return false;">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" for="email">E-Mail-Adresse</label>
            <input
              id="email"
              type="email"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="max@firma.de"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" for="password">Passwort</label>
            <input
              id="password"
              type="password"
              class="w-full px-4 py-2.5 rounded-xl border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors"
              placeholder="••••••••"
            />
          </div>

          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="w-4 h-4 rounded border-gray-300 dark:border-gray-600 text-brand-600 focus:ring-brand-500" />
              <span class="text-sm text-gray-600 dark:text-gray-300">Angemeldet bleiben</span>
            </label>
            <a href="#" class="text-sm text-brand-700 dark:text-brand-400 hover:text-brand-800 dark:hover:text-brand-300 font-medium">Passwort vergessen?</a>
          </div>

          <button
            type="submit"
            class="w-full py-2.5 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 transition-colors"
            onclick="document.getElementById('demo-hint').classList.remove('hidden'); return false;"
          >
            Anmelden
          </button>
        </form>

        <!-- Demo hint -->
        <div id="demo-hint" class="hidden mt-4 p-3 rounded-lg bg-amber-50 dark:bg-amber-950/40 border border-amber-200 dark:border-amber-900/50 text-sm text-amber-700 dark:text-amber-300 text-center">
          Dies ist eine Demo-Ansicht. Der Login ist noch nicht aktiv.
        </div>
      </div>

      <!-- Footer -->
      <div class="mt-6 text-center">
        <p class="text-xs text-gray-500 dark:text-gray-400">
          Noch kein Konto? <a href="/#kontakt" class="text-brand-700 dark:text-brand-400 hover:underline font-medium">Demo anfragen</a>
        </p>
        <p class="mt-4 text-xs text-gray-300 dark:text-gray-600">
          <a href="/impressum" class="hover:text-gray-500 dark:hover:text-gray-400 transition-colors">Impressum</a>
          {' · '}
          <a href="/datenschutz" class="hover:text-gray-500 dark:hover:text-gray-400 transition-colors">Datenschutz</a>
        </p>
      </div>
    </div>
  </main>
</Layout>
