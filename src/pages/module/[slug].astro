---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { module, type Modul } from '../../data/module';

export function getStaticPaths() {
  return module.map((m) => ({ params: { slug: m.slug }, props: { modul: m } }));
}

interface Props {
  modul: Modul;
}

const { modul } = Astro.props;
const siteUrl = 'https://vertoo.de';
const url = `${siteUrl}/module/${modul.slug}`;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: modul.name,
  name: modul.metaTitle,
  description: modul.metaDescription,
  provider: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)', url: siteUrl },
  areaServed: { '@type': 'Country', name: 'Deutschland' },
  isPartOf: { '@type': 'SoftwareApplication', name: 'VertooERP', applicationCategory: 'BusinessApplication' },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: modul.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Module', item: `${siteUrl}/module` },
    { '@type': 'ListItem', position: 3, name: modul.name, item: url },
  ],
};
---

<Layout title={modul.metaTitle} description={modul.metaDescription} jsonLd={[serviceLd, faqLd, breadcrumbLd]}>
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 hero-gradient overflow-hidden">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <nav aria-label="Brotkrümelnavigation" class="mb-6 text-sm text-gray-500 dark:text-gray-400">
          <a href="/" class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">Start</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href="/module" class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">Module</a>
        </nav>
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-50 dark:bg-brand-950/60 text-brand-700 dark:text-brand-300 text-xs font-medium mb-6">
          <span aria-hidden="true" class="inline-flex"><Icon name={`lucide:${modul.icon}`} class="w-3.5 h-3.5" /></span>
          {modul.hero.eyebrow}
        </span>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight tracking-tight">{modul.hero.headline}</h1>
        <p class="mt-6 text-lg sm:text-xl text-gray-500 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto">{modul.hero.subhead}</p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/#kontakt" class="w-full sm:w-auto px-8 py-3.5 rounded-xl bg-brand-700 text-white font-semibold hover:bg-brand-800 transition-all hover:shadow-lg hover:shadow-brand-700/25 text-center">Demo anfragen</a>
          <a href="/#module" class="w-full sm:w-auto px-8 py-3.5 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors text-center">Alle Module</a>
        </div>
      </div>
    </section>

    <!-- Was ist X (Definition, GEO) -->
    <section class="py-16 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4">Was ist {modul.name}?</h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">{modul.intro}</p>
      </div>
    </section>

    <!-- Painpoints -->
    <section class="py-16 lg:py-24 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Probleme</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{modul.painpoints.intro}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-4xl mx-auto">
          {modul.painpoints.items.map((p) => (
            <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
              <div aria-hidden="true" class="w-11 h-11 rounded-xl bg-brand-50 dark:bg-gray-900 text-brand-600 dark:text-brand-400 flex items-center justify-center mb-3"><Icon name={`lucide:${p.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{p.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">{p.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Funktionen</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">{modul.name} im Detail</h2>
          <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">{modul.features.intro}</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {modul.features.items.map((f) => (
            <article class="p-6 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover">
              <div aria-hidden="true" class="w-12 h-12 rounded-xl bg-brand-50 dark:bg-gray-800 text-brand-600 dark:text-brand-400 flex items-center justify-center mb-4"><Icon name={`lucide:${f.icon}`} class="w-6 h-6" /></div>
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">{f.name}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{f.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 lg:py-24 bg-gray-50 dark:bg-gray-900">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-12">
          <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Häufige Fragen</span>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Fragen zu {modul.name}</h2>
        </div>
        <div class="space-y-3">
          {modul.faq.map((item, i) => (
            <details class="group rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 p-5 sm:p-6 [&_summary::-webkit-details-marker]:hidden" open={i === 0}>
              <summary class="flex items-center justify-between cursor-pointer text-base sm:text-lg font-semibold text-gray-900 dark:text-white list-none gap-4">
                <span>{item.q}</span>
                <svg aria-hidden="true" class="w-5 h-5 shrink-0 text-brand-700 dark:text-brand-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-3 text-sm sm:text-base text-gray-600 dark:text-gray-300 leading-relaxed">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 lg:py-28 bg-brand-700">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white">{modul.cta.headline}</h2>
        <p class="mt-4 text-lg text-white/90 max-w-2xl mx-auto">{modul.cta.text}</p>
        <a href="/#kontakt" class="mt-8 inline-flex items-center justify-center px-8 py-3.5 rounded-xl bg-white text-brand-700 font-semibold hover:bg-brand-50 transition-colors">Demo anfragen</a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
