---
import ModulPage from '../../components/ModulPage.astro';
import { module } from '../../data/module';

export function getStaticPaths() {
  return module.map((m) => ({ params: { slug: m.slug }, props: { modul: m } }));
}

const { modul } = Astro.props;
---

<ModulPage modul={modul} lang="de" />
