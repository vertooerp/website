---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Seite nicht gefunden – VertooERP" noindex={true}>
  <Header />
  <main id="main-content" class="min-h-[70vh] flex items-center justify-center px-6 py-32 hero-gradient">
    <div class="text-center max-w-lg">
      <p class="text-7xl sm:text-8xl font-extrabold gradient-text">404</p>
      <h1 class="mt-6 text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
        Diese Seite gibt es nicht
      </h1>
      <p class="mt-4 text-gray-500 dark:text-gray-400">
        Die aufgerufene Seite wurde verschoben oder existiert nicht mehr. Vielleicht hilft einer dieser Wege weiter:
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="w-full sm:w-auto px-6 py-3 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 transition-colors">
          Zur Startseite
        </a>
        <a href="/#module" class="w-full sm:w-auto px-6 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold text-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          Module ansehen
        </a>
        <a href="/blog" class="w-full sm:w-auto px-6 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 font-semibold text-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">
          Zum Blog
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
