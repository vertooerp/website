---
import BranchePage from '../../components/BranchePage.astro';
import { branchen } from '../../data/branchen';

export function getStaticPaths() {
  return branchen.map((b) => ({ params: { slug: b.slug }, props: { branche: b } }));
}

const { branche } = Astro.props;
---

<BranchePage branche={branche} lang="de" />
