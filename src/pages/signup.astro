---
import Layout from '../layouts/Layout.astro';

// Endpoint der Master-Console (cross-origin). Operator setzt PUBLIC_CHECKOUT_ENDPOINT.
const checkoutEndpoint = import.meta.env.PUBLIC_CHECKOUT_ENDPOINT || 'https://console.vertoo.de/api/checkout';

const planLabels: Record<string, string> = {
  starter: 'Starter — 350 € / Monat',
  business: 'Business — 800 € / Monat',
};
---

<Layout title="Vertoo ERP – Registrierung" description="Vertoo ERP Self-Service-Registrierung: Tarif wählen, Firmendaten eingeben, sofort loslegen.">
  <main class="min-h-screen flex items-center justify-center px-6 py-16 bg-gray-50">
    <div class="w-full max-w-md">
      <a href="/#preise" class="text-sm text-brand-600 hover:text-brand-800">&larr; Zurück zu den Tarifen</a>
      <div class="mt-4 rounded-2xl bg-white border border-gray-200 p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-gray-900">Registrierung</h1>
        <p id="plan-label" class="mt-1 text-sm text-gray-500">Tarif wird geladen …</p>

        <form id="signup-form" class="mt-6 space-y-5" novalidate>
          <div>
            <label for="company" class="block text-sm font-medium text-gray-700">Firmenname</label>
            <input id="company" name="company" type="text" required minlength="2" maxlength="200" autocomplete="organization"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-brand-600 focus:ring-brand-600" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">E-Mail-Adresse</label>
            <input id="email" name="email" type="email" required autocomplete="email"
              class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-brand-600 focus:ring-brand-600" />
          </div>
          <div>
            <label for="subdomain" class="block text-sm font-medium text-gray-700">Wunsch-Adresse</label>
            <div class="mt-1 flex items-center rounded-lg border border-gray-300 focus-within:border-brand-600 focus-within:ring-1 focus-within:ring-brand-600">
              <input id="subdomain" name="subdomain" type="text" required pattern="[a-z][a-z0-9-]{2,29}" placeholder="meinefirma"
                class="w-full rounded-l-lg border-0 px-3 py-2 text-sm focus:ring-0" />
              <span class="px-3 py-2 text-sm text-gray-400 select-none">.vertoo.de</span>
            </div>
            <p class="mt-1 text-xs text-gray-400">Kleinbuchstaben, Ziffern, Bindestriche. Beginnt mit einem Buchstaben.</p>
          </div>
          <p id="error" class="hidden text-sm text-red-600" role="alert"></p>

          <button id="submit" type="submit"
            class="w-full py-3 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 disabled:opacity-60 disabled:cursor-not-allowed transition-colors">
            Weiter zur Zahlung
          </button>
          <p class="text-center text-xs text-gray-400">Sichere Bezahlung über Stripe. Kein Risiko — jederzeit kündbar.</p>
        </form>
      </div>
    </div>
  </main>

  <script define:vars={{ checkoutEndpoint, planLabels }}>
    const params = new URLSearchParams(window.location.search);
    const plan = params.get('plan');
    const labelEl = document.getElementById('plan-label');
    const form = document.getElementById('signup-form');
    const errorEl = document.getElementById('error');
    const submitBtn = document.getElementById('submit');

    // Nur self-service-Pläne zulassen; sonst zurück zu den Preisen.
    if (!plan || !planLabels[plan]) {
      window.location.href = '/#preise';
    } else {
      labelEl.textContent = 'Tarif: ' + planLabels[plan];
    }

    function showError(msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      if (!form.checkValidity()) { form.reportValidity(); return; }

      const payload = {
        plan,
        billingCycle: 'monthly',
        company: form.company.value.trim(),
        email: form.email.value.trim(),
        subdomain: form.subdomain.value.trim().toLowerCase(),
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Einen Moment …';
      try {
        const res = await fetch(checkoutEndpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.url) {
          window.location.href = data.url; // → Stripe Checkout
          return;
        }
        const messages = {
          rate_limited: 'Zu viele Anfragen. Bitte versuchen Sie es in einer Stunde erneut.',
          subdomain_taken: 'Diese Adresse ist bereits vergeben. Bitte wählen Sie eine andere.',
          subdomain_reserved: 'Diese Adresse ist nicht verfügbar. Bitte wählen Sie eine andere.',
          price_unavailable: 'Dieser Tarif ist derzeit nicht buchbar. Bitte kontaktieren Sie uns.',
          validation_failed: 'Bitte überprüfen Sie Ihre Eingaben.',
        };
        showError(data.message || messages[data.error] || 'Es ist ein Fehler aufgetreten. Bitte versuchen Sie es erneut.');
      } catch {
        showError('Verbindungsfehler. Bitte versuchen Sie es erneut.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Weiter zur Zahlung';
      }
    });
  </script>
</Layout>
