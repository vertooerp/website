---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { glossar } from '../data/glossar';

const siteUrl = 'https://vertoo.de';

const definedTermSetLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'VertooERP ERP-Glossar',
  description: 'Definitionen zentraler Begriffe rund um ERP, Buchhaltung, Handel und Digitalisierung für KMU und Mittelstand.',
  url: `${siteUrl}/glossar`,
  hasDefinedTerm: glossar.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.definition,
    url: `${siteUrl}/glossar#${t.slug}`,
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Glossar', item: `${siteUrl}/glossar` },
  ],
};
---

<Layout
  title="ERP-Glossar – VertooERP"
  description="Verständliche Definitionen zu ERP, GoBD, DSGVO, Dropshipping, XRechnung, Self-Hosting und weiteren Begriffen rund um Unternehmenssoftware für den Mittelstand."
  jsonLd={[definedTermSetLd, breadcrumbLd]}
>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-12 lg:pt-40 hero-gradient overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <nav aria-label="Brotkrümelnavigation" class="mb-6 text-sm text-gray-500 dark:text-gray-400">
          <a href="/" class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">Start</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <span class="text-gray-700 dark:text-gray-300">Glossar</span>
        </nav>
        <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Glossar</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">ERP-Begriffe verständlich erklärt</h1>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
          Kurze, klare Definitionen zu den wichtigsten Begriffen rund um ERP, Buchhaltung, Handel und Digitalisierung.
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <!-- Sprungnavigation -->
        <nav aria-label="Begriffe" class="flex flex-wrap gap-2 mb-12">
          {glossar.map((t) => (
            <a href={`#${t.slug}`} class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-brand-50 dark:hover:bg-gray-700 hover:text-brand-700 dark:hover:text-brand-400 transition-colors">
              {t.term}
            </a>
          ))}
        </nav>

        <dl class="space-y-10">
          {glossar.map((t) => (
            <div id={t.slug} class="scroll-mt-24">
              <dt class="text-xl font-bold text-gray-900 dark:text-white">{t.term}</dt>
              <dd class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">{t.definition}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
