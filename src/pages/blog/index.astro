---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { readingTimeMinutes } from '../../utils/reading-time';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Blog – VertooERP"
  description="Fachartikel rund um ERP, Self-Hosting, Buchhaltung, GoBD und Digitalisierung für kleine und mittlere Unternehmen."
>
  <Header />
  <main id="main-content">
    <section class="relative pt-32 pb-12 lg:pt-40 hero-gradient overflow-hidden">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <span class="text-sm font-medium text-brand-700 dark:text-brand-400 uppercase tracking-wider">Blog</span>
        <h1 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">Wissen für KMU</h1>
        <p class="mt-4 text-lg text-gray-500 dark:text-gray-400">
          Fachartikel zu ERP, Self-Hosting, Buchhaltung und Digitalisierung – praxisnah und ohne Marketing-Geschwätz.
        </p>
      </div>
    </section>

    <section class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto px-6">
        <ul class="space-y-5">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group block p-6 sm:p-8 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover hover:border-brand-200 dark:hover:border-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500"
              >
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-brand-50 dark:bg-gray-800 text-brand-700 dark:text-brand-400">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white group-hover:text-brand-700 dark:group-hover:text-brand-400 transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">{post.data.description}</p>
                <p class="mt-4 text-xs text-gray-500 dark:text-gray-400">
                  <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
                  <span class="mx-1.5" aria-hidden="true">·</span>
                  {readingTimeMinutes(post.body ?? '')} Min. Lesezeit
                </p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
