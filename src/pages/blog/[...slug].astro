---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { readingTimeMinutes } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const minutes = readingTimeMinutes(post.body ?? '');

// Verwandte Artikel: andere Beiträge mit den meisten gemeinsamen Tags
const related = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    post: p,
    shared: p.data.tags.filter((t) => post.data.tags.includes(t)).length,
  }))
  .sort((a, b) => b.shared - a.shared || b.post.data.pubDate.getTime() - a.post.data.pubDate.getTime())
  .slice(0, 2)
  .map((x) => x.post);

const siteUrl = 'https://vertoo.de';
const url = `${siteUrl}/blog/${post.id}`;
const dateFmt = (d: Date) =>
  d.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: { '@type': 'Organization', name: 'tap & type UG (haftungsbeschränkt)', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'VertooERP',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<Layout title={`${post.data.title} – VertooERP`} description={post.data.description} jsonLd={[articleLd, breadcrumbLd]}>
  <Header />
  <main id="main-content">
    <article class="pt-32 pb-20 lg:pt-40">
      <div class="max-w-3xl mx-auto px-6">
        <!-- Breadcrumb -->
        <nav aria-label="Brotkrümelnavigation" class="mb-8 text-sm text-gray-500 dark:text-gray-400">
          <a href="/" class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">Start</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href="/blog" class="hover:text-brand-700 dark:hover:text-brand-400 transition-colors">Blog</a>
        </nav>

        <!-- Header -->
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {post.data.tags.map((tag) => (
            <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-brand-50 dark:bg-gray-800 text-brand-700 dark:text-brand-400">
              {tag}
            </span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white">
          {post.data.title}
        </h1>
        <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
          <time datetime={post.data.pubDate.toISOString()}>{dateFmt(post.data.pubDate)}</time>
          <span class="mx-1.5" aria-hidden="true">·</span>
          {minutes} Min. Lesezeit
          {post.data.updatedDate && (
            <span> · aktualisiert {dateFmt(post.data.updatedDate)}</span>
          )}
        </p>

        <!-- Body -->
        <div class="prose prose-lg dark:prose-invert mt-10 max-w-none prose-headings:font-bold prose-a:text-brand-700 dark:prose-a:text-brand-400 prose-a:no-underline hover:prose-a:underline prose-th:text-left">
          <Content />
        </div>

        <!-- CTA -->
        <div class="mt-14 rounded-2xl bg-brand-50 dark:bg-brand-950/30 border border-brand-100 dark:border-brand-900/50 p-6 sm:p-8 text-center">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">VertooERP kennenlernen</h2>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
            Modulares ERP, self-gehostet, DSGVO- und GoBD-konform. Vereinbaren Sie eine unverbindliche Demo.
          </p>
          <a href="/#kontakt" class="mt-5 inline-flex items-center justify-center px-6 py-3 rounded-xl bg-brand-700 text-white font-semibold text-sm hover:bg-brand-800 transition-colors">
            Demo anfragen
          </a>
        </div>

        {related.length > 0 && (
          <aside class="mt-14 border-t border-gray-100 dark:border-gray-800 pt-10">
            <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-5">Verwandte Artikel</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {related.map((r) => (
                <a
                  href={`/blog/${r.id}`}
                  class="group block p-5 rounded-2xl border border-gray-100 dark:border-gray-800 bg-white dark:bg-gray-900 card-hover hover:border-brand-200 dark:hover:border-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500"
                >
                  <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-700 dark:group-hover:text-brand-400 transition-colors">
                    {r.data.title}
                  </h3>
                  <p class="mt-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed line-clamp-2">{r.data.description}</p>
                </a>
              ))}
            </div>
          </aside>
        )}
      </div>
    </article>
  </main>
  <Footer />
</Layout>
