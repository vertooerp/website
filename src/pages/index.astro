---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import UspStrip from '../components/UspStrip.astro';
import CompareStrip from '../components/CompareStrip.astro';
import Modules from '../components/Modules.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Pricing from '../components/Pricing.astro';
import UseCases from '../components/UseCases.astro';
import TechSecurity from '../components/TechSecurity.astro';
import SocialProof from '../components/SocialProof.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { faq } from '../data/faq';

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'VertooERP',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'ERP',
  operatingSystem: 'Web, iOS, Android (PWA)',
  description:
    'Modulare ERP-Plattform mit 20+ Modulen: Warenwirtschaft, Buchhaltung, Lagerverwaltung, Dropshipping, Aufgaben, Nachrichten, KI-Assistent und mehr. Multi-Mandant, Self-Hosting, DSGVO- und GoBD-konform.',
  url: 'https://vertoo.de',
  inLanguage: 'de-DE',
  offers: [
    {
      '@type': 'Offer',
      name: 'Starter',
      priceCurrency: 'EUR',
      price: '350',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '350',
        priceCurrency: 'EUR',
        unitText: 'MONTH',
      },
      description: 'Bis zu 3 Module, 3 Seats inklusive (+18 € je weiterer Seat).',
    },
    {
      '@type': 'Offer',
      name: 'Business',
      priceCurrency: 'EUR',
      price: '800',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '800',
        priceCurrency: 'EUR',
        unitText: 'MONTH',
      },
      description: 'Bis zu 12 Module, 10 Seats inklusive (+22 € je weiterer Seat).',
    },
    {
      '@type': 'Offer',
      name: 'Enterprise',
      priceCurrency: 'EUR',
      price: '1400',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: '1400',
        priceCurrency: 'EUR',
        unitText: 'MONTH',
      },
      description: 'Alle 20+ Module, 20 Seats inklusive (+28 € je weiterer Seat).',
    },
  ],
  provider: {
    '@type': 'Organization',
    name: 'tap & type UG (haftungsbeschränkt)',
    url: 'https://vertoo.de',
  },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<Layout jsonLd={[softwareApplicationLd, faqLd]} hasTranslation>
  <Header />
  <main id="main-content">
    <Hero />
    <UspStrip />
    <Modules />
    <HowItWorks />
    <SocialProof />
    <Pricing />
    <CompareStrip />
    <UseCases />
    <TechSecurity />
    <FAQ />
    <Contact />
  </main>
  <Footer />
</Layout>
